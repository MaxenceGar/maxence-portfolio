---
import LayoutPunchy from "../layouts/LayoutPunchy.astro";
---

<LayoutPunchy
  title="En construction — Maxence Garandel"
  description="Cette page n'est pas encore prête. Reviens bientôt, ou parlons-en directement."
  robots="noindex, nofollow"
>
  <div class="max-w-[1200px] mx-auto px-6 md:px-10 font-title">
    <section
      class="min-h-[80vh] flex items-center pt-28 md:pt-32 pb-20 md:pb-28"
    >
      <div class="max-w-2xl">
        <!-- Eyebrow -->
        <div
          class="inline-flex items-center gap-2 pl-2 pr-3.5 py-1 rounded-full bg-paper-2 border border-ink/5 mb-10"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange opacity-60"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2 w-2 bg-orange"
            ></span>
          </span>
          <span
            class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted"
          >
            En construction
          </span>
        </div>

        <!-- Headline -->
        <h1
          class="font-title font-medium text-4xl md:text-6xl lg:text-[64px] text-ink tracking-[-0.02em] leading-[1.02]"
        >
          Cette page<br />
          <span class="text-muted">est en cours d'écriture.</span>
        </h1>

        <!-- Sub -->
        <p
          class="mt-7 text-base md:text-lg text-ink-soft font-light leading-relaxed max-w-xl"
        >
          J'écris les case studies de mes projets un par un, sans bourrage de
          crâne ni générateur d'IA. Reviens dans quelques jours — ou si t'es
          pressé, on peut directement en parler.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-wrap items-center gap-3">
          <a
            href="https://calendly.com/maxgarandel-pro/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="cta-primary inline-flex items-center gap-2 bg-ink text-paper px-5 py-2.5 rounded-full text-sm font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper"
          >
            Réserver un call
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-3.5 h-3.5"
              aria-hidden="true"
            >
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </a>
          <a
            href="/"
            class="inline-flex items-center gap-2 text-ink px-5 py-2.5 rounded-full text-sm font-medium border border-ink/10 hover:border-ink/30 hover:bg-paper-2 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-3.5 h-3.5"
              aria-hidden="true"
            >
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Retour à la home
          </a>
        </div>
      </div>
    </section>
  </div>

  <style>
    .cta-primary:hover {
      background: #fc5d10;
    }
  </style>
</LayoutPunchy>
