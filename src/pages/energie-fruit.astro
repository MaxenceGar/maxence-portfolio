---
import LayoutPunchy from "../layouts/LayoutPunchy.astro";

// ─── PROJECT CASE STUDY TEMPLATE ────────────────────────────────────
// Pour créer un nouveau case study :
// 1. Duplique ce fichier sous src/pages/<slug>.astro
// 2. Remplace les variables ci-dessous (project, meta, sections, etc.)
// 3. Dépose les images dans public/images/ (format webp recommandé)
// 4. Retire le bloc <Testimonial> si pas de témoignage client
// ────────────────────────────────────────────────────────────────────

// ─── Données du projet ──────────────────────────────────────────────
const project = {
  name: "Energie Fruit",
  logo: "/images/logo-energie-fruit.svg",
  tagline: "Marque française de soins naturels, certifiée B Corp.",
  category: "E-commerce · Beauté",
  url: "https://www.energie-fruit.com",
  urlLabel: "energie-fruit.com",
  cover: "/images/energie-fruit-site.webp",
  status: "active", // active | completed | in-progress
};

// Méta quick-view (affichés en 4 colonnes sous le hero)
const meta = [
  { label: "Rôle", value: "Dev Shopify freelance" },
  { label: "Période", value: "Depuis 10/2025" },
  { label: "Statut", value: "Partenariat actif" },
  { label: "Stack", value: "Shopify OS 2.0" },
];

// Livrables concrets (section "Ce que j'ai fait")
const deliverables = [
  {
    title: "Pack builder",
    description:
      "Module d'upsell qui permet au client de composer son pack produit et d'augmenter le panier moyen.",
  },
  {
    title: "Jauge de panier",
    description:
      "Indicateur de progression vers la livraison offerte. FOMO positif = +AOV.",
  },
  {
    title: "Calendrier de l'avent",
    description:
      "Section saisonnière avec offre du jour, compte à rebours et animation.",
  },
  {
    title: "Animations trade",
    description:
      "Sections custom pour mettre en avant les opérations commerciales (Black Friday, lancements).",
  },
  {
    title: "Optimisation continue",
    description:
      "Itérations mensuelles sur le parcours, le SEO et les Core Web Vitals.",
  },
];

// Vidéo de présentation du site (remplace la galerie d'images)
const showcaseVideo = {
  src: "/video/ef.mp4",
  poster: "/images/energie-fruit-site.webp",
  alt: "Aperçu vidéo du site Energie Fruit",
};

// Témoignage (mettre à null pour masquer le bloc)
const testimonial = {
  quote:
    "Maxence travaille à nos côtés depuis le lancement du site en octobre 2025, et nous avons déjà prévu de poursuivre notre partenariat alors que nous ne pensions pas, au vu de la taille de notre PME, allouer un budget récurrent à ce poste de dépense. Il a su nous guider vers les priorités à mettre en place pour le lancement du e-shop et trouve toujours une solution pour retranscrire nos souhaits et idées sur le site : animation trade, pack builder, jauge panier, calendrier de l'avent, etc. Il est très flexible, disponible et réactif, ce qui est crucial pour une PME comme la nôtre.",
  author: "Juliette Gendre",
  role: "Eretail Manager",
  company: "Energie Fruit",
  companyLogo: "/images/logo-energie-fruit.svg",
};
---

<LayoutPunchy
  title={`${project.name} — Case study · Maxence Garandel`}
  description={`${project.tagline} Mon accompagnement en tant que freelance Shopify.`}
>
  <div class="max-w-[1200px] mx-auto px-6 md:px-10 font-title">
    <!-- ================================================================
         BREADCRUMB
         ================================================================ -->
    <div class="pt-28 md:pt-36">
      <a
        href="/#work"
        class="inline-flex items-center gap-2 text-sm text-muted hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper rounded-sm"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-4 h-4"
          aria-hidden="true"
        >
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Tous les projets
      </a>
    </div>

    <!-- ================================================================
         HERO PROJET
         ================================================================ -->
    <section class="pt-8 md:pt-12 pb-14 md:pb-20">
      <!-- Status pill -->
      {
        project.status === "active" && (
          <div class="inline-flex items-center gap-2 pl-2 pr-3.5 py-1 rounded-full bg-paper-2 border border-ink/5 mb-8">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange opacity-60" />
              <span class="relative inline-flex rounded-full h-2 w-2 bg-orange" />
            </span>
            <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted">
              {project.category} · client actif
            </span>
          </div>
        )
      }
      {
        project.status !== "active" && (
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-paper-2 border border-ink/5 mb-8">
            <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted">
              {project.category}
            </span>
          </div>
        )
      }

      <div
        class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-10 items-end"
      >
        <div>
          <!-- Headline -->
          <h1
            class="font-title font-medium text-4xl md:text-6xl lg:text-[68px] text-ink tracking-[-0.02em] leading-[1.02]"
          >
            {project.name}.
          </h1>
          <p
            class="mt-5 text-base md:text-lg text-ink-soft font-light leading-relaxed max-w-xl"
          >
            {project.tagline}
          </p>
        </div>

        <!-- CTA visit -->
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-ink text-paper px-5 py-2.5 rounded-full text-sm font-medium hover:bg-orange transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper self-start md:self-end"
        >
          Visiter {project.urlLabel}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-3.5 h-3.5"
            aria-hidden="true"
          >
            <line x1="7" y1="17" x2="17" y2="7"></line>
            <polyline points="7 7 17 7 17 17"></polyline>
          </svg>
        </a>
      </div>

      <!-- Meta grid (4 cols) -->
      <dl
        class="mt-12 md:mt-16 grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-6 border-t border-ink/10 pt-8"
      >
        {
          meta.map((m) => (
            <div>
              <dt class="font-mono text-[10px] uppercase tracking-[0.12em] text-muted">
                {m.label}
              </dt>
              <dd class="font-title font-medium text-base md:text-lg text-ink mt-1.5">
                {m.value}
              </dd>
            </div>
          ))
        }
      </dl>
    </section>

    <!-- ================================================================
         COVER IMAGE
         ================================================================ -->
    <section class="pb-20 md:pb-28">
      <div
        class="rounded-sm overflow-hidden border border-ink/20 bg-paper-2 aspect-16/10 md:aspect-video"
      >
        <img
          src={project.cover}
          alt={`${project.name} — aperçu du site`}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="w-full h-full object-cover object-top"
        />
      </div>
    </section>

    <!-- ================================================================
         CONTEXT / CHALLENGE
         ================================================================ -->
    <section class="pb-20 md:pb-28">
      <div class="max-w-3xl">
        <p
          class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted mb-4"
        >
          01 · Contexte
        </p>
        <h2
          class="font-title font-medium text-3xl md:text-4xl text-ink tracking-tight leading-[1.1]"
        >
          Lancer un e-shop à la hauteur de la marque.
        </h2>
        <div
          class="mt-6 space-y-5 text-base md:text-lg text-ink-soft font-light leading-relaxed"
        >
          <p>
            Energie Fruit, déjà distribuée dans plus de 200 points de vente en
            France, s'apprêtait à ouvrir son site e-commerce. Marque engagée,
            certifiée <strong class="font-medium text-ink">B Corp</strong>, vegan
            et à 95% d'ingrédients naturels : chaque détail de leur identité
            devait se retrouver sur le site.
          </p>
          <p>
            Il fallait quelqu'un de réactif qui comprenne vite leurs enjeux, qui
            sache prioriser pour un lancement serré, et qui puisse traduire des
            idées concrètes (pack builder, jauge livraison, compte à rebours,
            animations trade) en code propre — sans passer par une agence ou
            empiler 10 apps payantes.
          </p>
        </div>
      </div>
    </section>

    <!-- ================================================================
         DELIVERABLES / SOLUTION
         ================================================================ -->
    <section class="pb-20 md:pb-28">
      <div class="max-w-3xl mb-10 md:mb-12">
        <p
          class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted mb-4"
        >
          02 · Ce que j'ai fait
        </p>
        <h2
          class="font-title font-medium text-3xl md:text-4xl text-ink tracking-tight leading-[1.1]"
        >
          Des sections custom qui font vendre.
        </h2>
        <p
          class="mt-6 text-base md:text-lg text-ink-soft font-light leading-relaxed"
        >
          Tout codé en natif dans le thème. Zéro app en plus, zéro dépendance
          externe, 100% éditable depuis l'éditeur Shopify.
        </p>
      </div>

      <ul
        class="grid grid-cols-1 md:grid-cols-2 gap-px bg-ink/6 border border-ink/6 rounded-sm overflow-hidden list-none"
      >
        {
          deliverables.map((d, i) => (
            <li class="bg-paper p-6 md:p-8">
              <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-orange mb-3">
                {String(i + 1).padStart(2, "0")}
              </div>
              <h3 class="font-title font-medium text-lg text-ink mb-2 tracking-tight">
                {d.title}
              </h3>
              <p class="font-light text-sm text-ink-soft leading-relaxed">
                {d.description}
              </p>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- ================================================================
         GALLERY
         ================================================================ -->
    <section class="pb-20 md:pb-28">
      <div class="mb-10">
        <p
          class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted mb-4"
        >
          03 · Aperçus
        </p>
        <h2
          class="font-title font-medium text-3xl md:text-4xl text-ink tracking-tight"
        >
          Le site en détail.
        </h2>
      </div>

      <div
        class="rounded-sm overflow-hidden border border-ink/20 bg-ink aspect-video"
      >
        <video
          src={showcaseVideo.src}
          poster={showcaseVideo.poster}
          autoplay
          loop
          muted
          playsinline
          preload="metadata"
          aria-label={showcaseVideo.alt}
          class="w-full h-full object-cover"
        ></video>
      </div>
    </section>

    <!-- ================================================================
         TESTIMONIAL (conditional)
         ================================================================ -->
    {
      testimonial && (
        <section class="pb-20 md:pb-28">
          <div class="max-w-4xl">
            <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted mb-8">
              04 · Ce qu'en dit la cliente
            </p>

            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-10 h-10 text-orange mb-6"
              aria-hidden="true"
            >
              <path d="M7.17 8.5c-1.94 0-3.5 1.56-3.5 3.5s1.56 3.5 3.5 3.5c0 1.93-1.57 3.5-3.5 3.5v2c3.03 0 5.5-2.47 5.5-5.5V12c0-1.93-1.57-3.5-3.5-3.5zm9.33 0c-1.93 0-3.5 1.56-3.5 3.5s1.57 3.5 3.5 3.5c0 1.93-1.57 3.5-3.5 3.5v2c3.03 0 5.5-2.47 5.5-5.5V12c0-1.93-1.57-3.5-3.5-3.5z" />
            </svg>

            <blockquote>
              <p class="font-title font-light text-xl md:text-2xl lg:text-[28px] text-ink leading-[1.4] tracking-[-0.01em]">
                {testimonial.quote}
              </p>
            </blockquote>

            <figcaption class="mt-10 flex items-center gap-5 pt-6 border-t border-ink/10">
              {testimonial.companyLogo && (
                <img
                  src={testimonial.companyLogo}
                  alt={testimonial.company}
                  loading="lazy"
                  decoding="async"
                  class="h-7 md:h-8 w-auto shrink-0"
                />
              )}
              <div class="border-l border-ink/15 pl-5">
                <p class="font-title font-medium text-ink text-sm md:text-base">
                  {testimonial.author}
                </p>
                <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-muted mt-0.5">
                  {testimonial.role} · {testimonial.company}
                </p>
              </div>
            </figcaption>
          </div>
        </section>
      )
    }

    <!-- ================================================================
         FINAL CTA
         ================================================================ -->
    <section class="pb-24 md:pb-32">
      <div
        class="relative overflow-hidden rounded-sm bg-ink text-paper p-10 md:p-16 text-center"
      >
        <div
          class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-orange opacity-15 blur-3xl pointer-events-none"
          aria-hidden="true"
        >
        </div>

        <div class="relative max-w-2xl mx-auto">
          <p
            class="font-mono text-[10px] uppercase tracking-[0.15em] text-orange mb-5"
          >
            Un projet similaire ?
          </p>
          <h2
            class="font-title font-medium text-3xl md:text-5xl tracking-tight leading-[1.05]"
          >
            Parle-moi de ton Shopify.
          </h2>
          <p
            class="mt-5 text-base md:text-lg text-paper/70 font-light leading-relaxed"
          >
            30 minutes, gratuit, sans engagement. On regarde ton besoin, je te
            dis honnêtement si je peux aider.
          </p>

          <div
            class="mt-8 flex flex-wrap items-center justify-center gap-3"
          >
            <a
              href="https://calendly.com/maxgarandel-pro/30min"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-paper text-ink px-6 py-3 rounded-full text-sm font-medium hover:bg-orange hover:text-paper transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-ink"
            >
              Réserver un call
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-4 h-4"
                aria-hidden="true"
              >
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </a>
            <a
              href="/#work"
              class="inline-flex items-center gap-2 text-paper/80 hover:text-paper px-3 py-2 text-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-ink rounded-full"
            >
              voir les autres projets
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</LayoutPunchy>
