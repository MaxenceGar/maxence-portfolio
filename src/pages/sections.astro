---
import LayoutPunchy from "../layouts/LayoutPunchy.astro";

// Page privée — accessible via le lien envoyé par email après inscription.
// noindex + nofollow (voir layout).
//
// ─── COMMENT AJOUTER UNE SECTION ───────────────────────────────────
// 1. Crée un fichier dans src/sections-liquid/<slug>.liquid avec ton code
// 2. Importe-le ici en bas des imports avec ?raw (voir exemple ci-dessous)
// 3. Ajoute une entrée dans le tableau `sections`
// 4. Mets la miniature dans public/images/sections/<slug>.webp (ou null)
// ───────────────────────────────────────────────────────────────────

import mothersDayCountdown from "../sections-liquid/mothers-day-countdown.liquid?raw";

const sections = [
  {
    slug: "mothers-day-countdown",
    title: "Fête des mères — Countdown",
    description:
      "Compte à rebours animé jusqu'à la fête des mères. Date limite de livraison, pétales flottants, CTA dégradé. Zéro dépendance.",
    thumbnail: "/images/sections/mothers-day-countdown.webp",
    tags: ["countdown", "hero", "saisonnier"],
    liquid: mothersDayCountdown,
  },
];
---

<LayoutPunchy
  title="Ma bibliothèque de sections Shopify"
  description="Bibliothèque privée — sections Shopify prêtes à coller."
  robots="noindex, nofollow, noarchive"
>
  <div class="max-w-[1200px] mx-auto px-6 md:px-10 font-title">
    <!-- ================================================================
         HERO — premium, Stripe/Linear-inspired
         ================================================================ -->
    <section class="pt-32 md:pt-40 pb-20 md:pb-28">
      <div class="max-w-3xl">
        <!-- Eyebrow pill -->
        <div
          class="inline-flex items-center gap-2 pl-2 pr-3.5 py-1 rounded-full bg-paper-2 border border-ink/5 mb-10"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange opacity-60"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2 w-2 bg-orange"
            ></span>
          </span>
          <span
            class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted"
          >
            Private library · accès membre
          </span>
        </div>

        <!-- Headline -->
        <h1
          class="font-title font-medium text-4xl md:text-6xl lg:text-[68px] text-ink tracking-[-0.02em] leading-[1.02]"
        >
          Sections Shopify,<br />
          <span class="text-muted">prêtes à copier.</span>
        </h1>

        <!-- Sub -->
        <p
          class="mt-7 text-base md:text-lg text-ink-soft font-light leading-relaxed max-w-2xl"
        >
          Des sections testées, compatibles OS 2.0, que tu colles dans ton
          thème en quelques secondes. Nouvelles sections ajoutées chaque mois.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-wrap items-center gap-3">
          <a
            href="#library"
            class="cta-primary inline-flex items-center gap-2 bg-ink text-paper px-5 py-2.5 rounded-full text-sm font-medium transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper"
          >
            Voir les sections
            <span class="cta-arrow transition-transform">↓</span>
          </a>
          <a
            href="#how-it-works"
            class="inline-flex items-center gap-2 text-ink px-5 py-2.5 rounded-full text-sm font-medium border border-ink/10 hover:border-ink/30 hover:bg-paper-2 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper"
          >
            Comment ça marche
          </a>
        </div>

        <!-- Stats strip -->
        <div
          class="mt-16 pt-6 border-t border-ink/5 flex flex-wrap items-center gap-x-8 gap-y-2 font-mono text-[11px] uppercase tracking-[0.12em] text-muted"
        >
          <span>
            <strong class="text-ink font-medium normal-case font-title text-sm"
              >{sections.length}</strong
            >
            {sections.length > 1 ? " sections" : " section"} dispo
          </span>
          <span class="inline-block w-1 h-1 rounded-full bg-ink/20"></span>
          <span>
            Mis à jour
            <strong class="text-ink font-medium normal-case font-title text-sm"
              >chaque mois</strong
            >
          </span>
          <span class="inline-block w-1 h-1 rounded-full bg-ink/20"></span>
          <span>
            Compatible
            <strong class="text-ink font-medium normal-case font-title text-sm"
              >Shopify OS 2.0</strong
            >
          </span>
        </div>
      </div>
    </section>

    <!-- ================================================================
         HOW IT WORKS — 3 steps horizontal
         ================================================================ -->
    <section id="how-it-works" class="pb-20 md:pb-28">
      <div class="mb-10">
        <p
          class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted mb-2"
        >
          Comment ça marche
        </p>
        <h2
          class="font-title font-medium text-2xl md:text-3xl text-ink tracking-tight"
        >
          Trois étapes, deux minutes.
        </h2>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-3 gap-px bg-ink/[0.06] border border-ink/[0.06] rounded-2xl overflow-hidden"
      >
        <div class="bg-paper p-8 md:p-10">
          <div
            class="font-mono text-[10px] uppercase tracking-[0.15em] text-orange mb-5"
          >
            01 · Copie
          </div>
          <h3
            class="font-title font-medium text-base md:text-lg text-ink mb-2"
          >
            Un clic sur une carte.
          </h3>
          <p
            class="text-sm text-ink-soft font-light leading-relaxed"
          >
            Le code Liquid complet (HTML + CSS + JS + schema) est copié
            dans ton presse-papier.
          </p>
        </div>

        <div class="bg-paper p-8 md:p-10">
          <div
            class="font-mono text-[10px] uppercase tracking-[0.15em] text-orange mb-5"
          >
            02 · Colle
          </div>
          <h3
            class="font-title font-medium text-base md:text-lg text-ink mb-2"
          >
            Dans <code
              class="font-mono text-[13px] bg-paper-2 px-1.5 py-0.5 rounded border border-ink/5"
              >sections/</code
            > de ton thème.
          </h3>
          <p
            class="text-sm text-ink-soft font-light leading-relaxed"
          >
            Nouveau fichier
            <code class="font-mono text-[12px] text-ink">.liquid</code>,
            colle, enregistre.
          </p>
        </div>

        <div class="bg-paper p-8 md:p-10">
          <div
            class="font-mono text-[10px] uppercase tracking-[0.15em] text-orange mb-5"
          >
            03 · Customise
          </div>
          <h3
            class="font-title font-medium text-base md:text-lg text-ink mb-2"
          >
            Depuis l'éditeur Shopify.
          </h3>
          <p
            class="text-sm text-ink-soft font-light leading-relaxed"
          >
            Toutes les sections sont 100% éditables : textes, couleurs,
            dates, images.
          </p>
        </div>
      </div>

      <!-- Toggle tuto video -->
      <details class="mt-6 group">
        <summary
          class="cursor-pointer inline-flex items-center gap-2 text-sm text-ink-soft hover:text-ink transition-colors list-none rounded-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper"
        >
          <span
            class="inline-block w-7 h-7 rounded-full bg-paper-2 border border-ink/10 flex items-center justify-center text-xs group-open:rotate-45 transition-transform"
            >+</span
          >
          <span class="font-light">Voir le tuto en vidéo (2 min)</span>
        </summary>
        <div
          class="mt-6 aspect-video rounded-xl overflow-hidden bg-ink ring-1 ring-ink/5"
        >
          <iframe
            src="https://www.youtube-nocookie.com/embed/52bNwBEpiDk?rel=0"
            title="Tuto — comment installer une section Shopify"
            loading="lazy"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            class="w-full h-full"
          ></iframe>
        </div>
      </details>
    </section>

    <!-- ================================================================
         LIBRARY — premium grid
         ================================================================ -->
    <section id="library" class="pb-20 md:pb-28 scroll-mt-20">
      <!-- Header -->
      <div
        class="flex items-end justify-between mb-10 pb-5 border-b border-ink/10"
      >
        <div>
          <p
            class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted mb-2"
          >
            La bibliothèque
          </p>
          <h2
            class="font-title font-medium text-2xl md:text-3xl text-ink tracking-tight"
          >
            Toutes les sections.
          </h2>
        </div>
        <span
          class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted"
        >
          Clic pour copier
        </span>
      </div>

      <!-- Grid -->
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8"
      >
        {
          sections.map((s) => (
            <button
              type="button"
              class="section-card group text-left flex flex-col transition-all relative rounded-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-4 focus-visible:ring-offset-paper"
              data-slug={s.slug}
              data-liquid={s.liquid}
              data-cursor="hover"
              aria-label={`Copier le code Liquid de ${s.title}`}
            >
              <!-- Thumbnail -->
              <div class="thumbnail aspect-[4/3] bg-paper-2 rounded-xl overflow-hidden relative ring-1 ring-ink/5 transition-all">
                {s.thumbnail ? (
                  <img
                    src={s.thumbnail}
                    alt={`Aperçu ${s.title}`}
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover thumbnail-img transition-transform duration-500"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="font-mono text-[10px] uppercase tracking-wider text-muted">
                      {s.slug}
                    </span>
                  </div>
                )}

                <!-- Hover CTA overlay -->
                <div class="absolute inset-x-0 bottom-0 p-4 opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 pointer-events-none">
                  <div class="inline-flex items-center gap-2 bg-ink text-paper px-3 py-1.5 rounded-full text-xs font-medium shadow-lg">
                    <span class="copy-icon">⌘</span>
                    <span class="copy-text">Copier le code</span>
                  </div>
                </div>
              </div>

              <!-- Meta -->
              <div class="mt-4 flex flex-col gap-1.5 px-0.5">
                <div class="flex items-baseline justify-between gap-3">
                  <h3 class="font-title font-medium text-[15px] md:text-base text-ink leading-snug">
                    {s.title}
                  </h3>
                  {s.tags && s.tags[0] && (
                    <span class="font-mono text-[10px] uppercase tracking-wider text-muted shrink-0">
                      {s.tags[0]}
                    </span>
                  )}
                </div>
                <p class="font-light text-[13px] text-ink-soft leading-relaxed line-clamp-2">
                  {s.description}
                </p>
              </div>
            </button>
          ))
        }
      </div>
    </section>

    <!-- ================================================================
         SOFT CTA — besoin d'un dev custom ?
         ================================================================ -->
    <section class="pb-24 md:pb-32">
      <div
        class="relative overflow-hidden rounded-sm bg-ink text-paper p-10 md:p-16"
      >
        <!-- Gradient accent -->
        <div
          class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-orange opacity-15 blur-3xl pointer-events-none"
          aria-hidden="true"
        ></div>

        <div class="relative max-w-2xl">
          <p
            class="font-mono text-[10px] uppercase tracking-[0.15em] text-orange mb-5"
          >
            Besoin d'aller plus loin ?
          </p>
          <h2
            class="font-title font-medium text-3xl md:text-5xl tracking-tight leading-[1.05]"
          >
            Une section sur-mesure pour ta boutique ?
          </h2>
          <p
            class="mt-5 text-base md:text-lg text-paper/70 font-light leading-relaxed"
          >
            Tu cherches quelque chose de spécifique que tu ne trouves pas
            ici ? On en discute 30 minutes, je te dis si je peux t'aider.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a
              href="/#contact"
              class="inline-flex items-center gap-2 bg-paper text-ink px-5 py-2.5 rounded-full text-sm font-medium hover:bg-orange hover:text-paper transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-ink"
            >
              Réserver un call
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-4 h-4"
                aria-hidden="true"
              >
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </a>
            <span class="text-paper/50 text-sm font-mono">
              gratuit · sans engagement
            </span>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Toast (assertive region pour que les lecteurs d'écran l'annoncent) -->
  <div
    id="copy-toast"
    role="status"
    aria-live="polite"
    class="fixed bottom-6 left-1/2 -translate-x-1/2 translate-y-4 opacity-0 pointer-events-none z-50 inline-flex items-center gap-2 bg-ink text-paper rounded-full pl-3 pr-4 py-2 font-title text-sm transition-all duration-200 shadow-xl ring-1 ring-white/10"
  >
    <span
      id="copy-toast-icon"
      class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-orange shrink-0"
      aria-hidden="true"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="w-3 h-3 text-ink"
      >
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </span>
    <span id="copy-toast-text">Section copiée</span>
  </div>

  <style>
    .cta-primary:hover {
      background: #fc5d10;
    }
    .cta-primary:hover .cta-arrow {
      transform: translateY(2px);
    }

    .section-card {
      cursor: pointer;
    }
    .section-card .thumbnail {
      box-shadow: inset 0 0 0 1px rgba(26, 26, 26, 0.05);
      transition: box-shadow 200ms ease;
    }
    .section-card:hover .thumbnail {
      box-shadow: inset 0 0 0 1px rgba(26, 26, 26, 0.2);
    }
    .section-card:hover .thumbnail-img {
      transform: scale(1.03);
    }
    .section-card:hover h3 {
      color: #fc5d10;
    }
    .section-card.copied .thumbnail {
      box-shadow: 0 0 0 2px #fc5d10;
    }
    #copy-toast.on {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    #copy-toast.error #copy-toast-icon {
      background: #dc2626;
    }

    @media (prefers-reduced-motion: reduce) {
      .cta-arrow,
      .thumbnail-img,
      #copy-toast,
      .section-card,
      .section-card *,
      .animate-ping {
        animation: none !important;
        transition: none !important;
      }
      .section-card:hover .thumbnail-img {
        transform: none !important;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const toast = document.getElementById("copy-toast");
      const toastText = document.getElementById("copy-toast-text");
      let toastTO;

      function showToast(msg, isError) {
        if (!toast || !toastText) return;
        toastText.textContent = msg;
        toast.classList.toggle("error", !!isError);
        toast.classList.add("on");
        clearTimeout(toastTO);
        toastTO = setTimeout(() => toast.classList.remove("on"), 1800);
      }

      document.querySelectorAll(".section-card").forEach((card) => {
        card.addEventListener("click", async () => {
          const code = card.dataset.liquid;
          const title = card.getAttribute("aria-label") || "Section";
          if (!code) return;
          try {
            await navigator.clipboard.writeText(code);
            card.classList.add("copied");
            showToast("Code copié dans le presse-papier", false);
            setTimeout(() => card.classList.remove("copied"), 1800);
          } catch (e) {
            showToast("Erreur, impossible de copier", true);
          }
        });
      });
    })();
  </script>
</LayoutPunchy>
