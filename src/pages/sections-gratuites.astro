---
import LayoutPunchy from "../layouts/LayoutPunchy.astro";

const bullets = [
  "Compatible Shopify OS 2.0 (Dawn et la majorité des thèmes)",
  "100% customisable depuis le Customizer",
  "Zéro dépendance, zéro app à installer",
  "Nouvelle section chaque mois",
];

const faq = [
  {
    q: "C'est vraiment gratuit ?",
    a: "Oui, 100%. Tu laisses ton email, tu reçois le lien privé vers la bibliothèque. Zéro carte bancaire demandée, zéro piège d'essai gratuit.",
  },
  {
    q: "C'est pour quel type de thème Shopify ?",
    a: "Toutes les sections sont pensées pour Shopify OS 2.0 — ça marche sur Dawn et la quasi-totalité des thèmes modernes du store.",
  },
  {
    q: "Tu vas me spammer ?",
    a: "Non. Je t'envoie le lien, puis un mail seulement quand j'ajoute une nouvelle section (1 à 2 fois par mois max). Désinscription en 1 clic.",
  },
  {
    q: "Je peux les utiliser chez mes clients ?",
    a: "Oui — usage personnel et client OK. Tu ne peux juste pas revendre les fichiers tels quels sous ton propre nom.",
  },
];
---

<LayoutPunchy
  title="Sections Shopify gratuites — copie, colle, personnalise"
  description="Reçois gratuitement des sections Shopify prêtes à copier-coller. Compatibles OS 2.0, 100% personnalisables, nouvelle fournée chaque mois. Zéro spam."
>
  <div class="max-w-[1200px] mx-auto px-6 md:px-10 font-title">
    <!-- ================================================================
         HERO + FORM — above the fold priority
         ================================================================ -->
    <section class="pt-32 md:pt-40 pb-20 md:pb-28">
      <div class="max-w-2xl mx-auto text-center">
        <!-- Eyebrow pill -->
        <div
          class="inline-flex items-center gap-2 pl-2 pr-3.5 py-1 rounded-full bg-paper-2 border border-ink/5 mb-10"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange opacity-60"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2 w-2 bg-orange"
            ></span>
          </span>
          <span
            class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted"
          >
            Gratuit · accès immédiat
          </span>
        </div>

        <!-- Headline -->
        <h1
          class="font-title font-medium text-4xl md:text-6xl lg:text-[68px] text-ink tracking-[-0.02em] leading-[1.02]"
        >
          Sections Shopify,<br />
          <span class="text-muted">gratuites.</span>
        </h1>

        <!-- Sub -->
        <p
          class="mt-7 text-base md:text-lg text-ink-soft font-light leading-relaxed max-w-xl mx-auto"
        >
          Une bibliothèque privée de sections Liquid à copier-coller dans ton
          thème. Compatible OS 2.0, setup en 15 secondes, nouvelle section
          chaque mois.
        </p>

        <!-- Form card inline -->
        <div
          id="form"
          class="mt-12 md:mt-14 mx-auto max-w-md bg-paper border border-ink/10 rounded-2xl p-5 md:p-6 text-left shadow-sm"
        >
          <p
            class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted mb-1"
          >
            Reçois le lien par email
          </p>
          <h2
            class="font-title font-medium text-lg md:text-xl text-ink leading-snug mb-4"
          >
            Ton email, le lien arrive.
          </h2>

          <!-- Embed Tally (dynamic height) -->
          <iframe
            data-tally-src="https://tally.so/embed/rj0B5l?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
            loading="lazy"
            width="100%"
            height="200"
            frameborder="0"
            marginheight="0"
            marginwidth="0"
            title="Inscription sections Shopify gratuites"
            class="block w-full"
          ></iframe>

          <!-- RGPD reassurance -->
          <div
            class="mt-4 pt-4 border-t border-ink/5 flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.12em] text-muted"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-3.5 h-3.5 text-orange shrink-0"
              aria-hidden="true"
            >
              <path
                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
              ></path>
            </svg>
            <span>pas de spam · désinscription 1 clic · rgpd friendly</span>
          </div>
        </div>

        <!-- Stats strip -->
        <div
          class="mt-12 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 font-mono text-[11px] uppercase tracking-[0.12em] text-muted"
        >
          <span>Accès en <strong class="text-ink font-medium normal-case font-title text-sm">5 secondes</strong></span>
          <span class="inline-block w-1 h-1 rounded-full bg-ink/20"></span>
          <span>Mise à jour <strong class="text-ink font-medium normal-case font-title text-sm">mensuelle</strong></span>
          <span class="inline-block w-1 h-1 rounded-full bg-ink/20"></span>
          <span><strong class="text-ink font-medium normal-case font-title text-sm">0€</strong> à vie</span>
        </div>
      </div>
    </section>

    <!-- ================================================================
         PREVIEW — ce qui arrive dans la boîte (tangibilité)
         ================================================================ -->
    <section class="pb-20 md:pb-28">
      <div class="mb-10 text-center">
        <p
          class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted mb-2"
        >
          Aperçu de la bibliothèque
        </p>
        <h2
          class="font-title font-medium text-2xl md:text-3xl text-ink tracking-tight"
        >
          Voilà ce qui arrive dans ta boîte.
        </h2>
      </div>

      <!-- Preview card -->
      <div
        class="bg-paper-2 rounded-3xl p-6 md:p-10 lg:p-12 border border-ink/5"
      >
        <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
          <!-- Thumbnail with browser frame -->
          <div class="browser-frame bg-paper rounded-xl overflow-hidden ring-1 ring-ink/10 shadow-xl">
            <div
              class="flex items-center gap-1.5 px-4 py-3 border-b border-ink/5 bg-paper-2"
            >
              <span class="w-2.5 h-2.5 rounded-full bg-ink/15"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ink/15"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ink/15"></span>
              <div
                class="ml-3 flex-1 text-center font-mono text-[10px] text-muted truncate"
              >
                preview · mothers-day-countdown
              </div>
            </div>
            <img
              src="/images/sections/mothers-day-countdown.webp"
              alt="Aperçu — section Fête des mères avec compte à rebours"
              loading="lazy"
              decoding="async"
              class="w-full h-auto block"
            />
          </div>

          <!-- Preview info -->
          <div>
            <div
              class="inline-flex items-center gap-2 px-2.5 py-1 rounded-full bg-paper border border-ink/10 mb-4"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
              <span
                class="font-mono text-[10px] uppercase tracking-[0.12em] text-muted"
              >
                Dernière section ajoutée
              </span>
            </div>
            <h3
              class="font-title font-medium text-2xl md:text-3xl text-ink tracking-tight mb-3"
            >
              Fête des mères — Countdown.
            </h3>
            <p
              class="font-light text-base text-ink-soft leading-relaxed mb-6"
            >
              Compte à rebours animé jusqu'à la fête des mères, date limite
              de livraison, pétales flottants, CTA dégradé. Zéro dépendance,
              100% personnalisable.
            </p>

            <!-- Features list with SVG checks -->
            <ul class="space-y-2.5">
              {
                bullets.map((b) => (
                  <li class="flex items-start gap-2.5 text-sm text-ink font-light">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="w-4 h-4 text-orange shrink-0 mt-0.5"
                      aria-hidden="true"
                    >
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    <span>{b}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <!-- Upcoming teaser -->
        <div
          class="mt-10 pt-8 border-t border-ink/5 flex flex-wrap items-center justify-between gap-4"
        >
          <p
            class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted"
          >
            + nouvelles sections chaque mois
          </p>
          <a
            href="#form"
            class="inline-flex items-center gap-2 text-sm font-medium text-ink hover:text-orange transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper-2 rounded-full"
          >
            Je veux accéder à la bibliothèque
            <span aria-hidden="true">↑</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================================
         FAQ
         ================================================================ -->
    <section class="pb-20 md:pb-28">
      <div class="max-w-2xl mx-auto">
        <div class="mb-10">
          <p
            class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted mb-2"
          >
            FAQ
          </p>
          <h2
            class="font-title font-medium text-2xl md:text-3xl text-ink tracking-tight"
          >
            Les questions qu'on pose.
          </h2>
        </div>

        <div class="divide-y divide-ink/10 border-y border-ink/10">
          {
            faq.map((item) => (
              <details class="group">
                <summary
                  class="flex items-start justify-between gap-6 py-5 cursor-pointer list-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper rounded-sm"
                >
                  <span class="font-title font-medium text-base md:text-lg text-ink leading-snug">
                    {item.q}
                  </span>
                  <span
                    class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-paper-2 text-ink group-open:bg-orange group-open:text-paper group-open:rotate-45 transition-all shrink-0"
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="w-4 h-4"
                    >
                      <line x1="12" y1="5" x2="12" y2="19" />
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                  </span>
                </summary>
                <p class="font-light text-sm md:text-base text-ink-soft leading-relaxed pb-5 pr-10">
                  {item.a}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ================================================================
         BOTTOM CTA — re-pitch minimal
         ================================================================ -->
    <section class="pb-24 md:pb-32">
      <div
        class="relative overflow-hidden rounded-3xl bg-ink text-paper p-10 md:p-16 text-center"
      >
        <!-- Gradient accent -->
        <div
          class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-orange opacity-15 blur-3xl pointer-events-none"
          aria-hidden="true"
        ></div>
        <div
          class="absolute -bottom-32 -left-32 w-96 h-96 rounded-full bg-orange opacity-10 blur-3xl pointer-events-none"
          aria-hidden="true"
        ></div>

        <div class="relative max-w-xl mx-auto">
          <h2
            class="font-title font-medium text-3xl md:text-5xl tracking-tight leading-[1.05]"
          >
            On se retrouve dans ta boîte mail ?
          </h2>
          <p
            class="mt-5 text-base md:text-lg text-paper/70 font-light leading-relaxed"
          >
            Ton email, un lien privé, une nouvelle section chaque mois. Tu
            peux arrêter en 1 clic.
          </p>
          <a
            href="#form"
            class="mt-8 inline-flex items-center gap-2 bg-paper text-ink px-6 py-3 rounded-full text-sm font-medium hover:bg-orange hover:text-paper transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-ink"
          >
            Donner mon email
            <span aria-hidden="true">↑</span>
          </a>
        </div>
      </div>
    </section>
  </div>

  <style>
    @media (prefers-reduced-motion: reduce) {
      .animate-ping,
      .group-open\:rotate-45 {
        animation: none !important;
        transition: none !important;
      }
      summary .group-open\:rotate-45,
      details[open] summary span {
        transform: none !important;
      }
    }
  </style>

  <!-- Tally embed loader (dynamic height) -->
  <script is:inline src="https://tally.so/widgets/embed.js" async></script>
</LayoutPunchy>
