---
import LayoutPunchy from "../layouts/LayoutPunchy.astro";

const features = [
  {
    n: "01",
    title: "Plus de conversions",
    hint: "UX pensée pour transformer : quick-add, sticky ATC, wishlist — chaque détail pousse à l'achat.",
  },
  {
    n: "02",
    title: "Panier moyen boosté",
    hint: "Upsell, cross-sell, bundles, paliers livraison gratuite — tu vends plus à chaque commande.",
  },
  {
    n: "03",
    title: "Vitesse & SEO",
    hint: "Code ultra-léger, zéro dépendance. Google PageSpeed t'adore, tes visiteurs aussi.",
  },
  {
    n: "04",
    title: "Moins d'apps, plus de CA",
    hint: "400 à 1000€/mois économisés : tout ce que tu payais en apps est déjà natif dans Experaise.",
  },
  {
    n: "05",
    title: "N'importe quelle boutique",
    hint: "Mode, beauté, food, luxe, B2B — le système de blocks s'adapte à ton univers.",
  },
  {
    n: "06",
    title: "Lancée en 15 minutes",
    hint: "Modèles pré-construits activables en 1 clic, drag & drop Shopify 2.0. Zéro code.",
  },
];

const sections = [
  "Hero",
  "Product information",
  "Main collection",
  "Cart drawer",
  "Wishlist drawer",
  "Product hotspots",
  "Predictive search",
  "Marquee",
  "Mega menu",
  "Countdown",
  "Accordion",
  "Slider",
];

const metrics = [
  { value: "+40", label: "Fonctionnalités conversion" },
  { value: "+100", label: "Fonctionnalités au total" },
  { value: "~500€", label: "Économisés chaque mois" },
  { value: "15 min", label: "Pour lancer ta boutique" },
];

const faq = [
  {
    q: "Ça marche pour quel type de boutique ?",
    a: "Mode, beauté, food, marque premium, B2B, lancement produit… Experaise s'adapte à n'importe quel univers grâce à son système de blocks universels. Tu façonnes le thème pour matcher ton identité, pas l'inverse.",
  },
  {
    q: "Est-ce que je peux vraiment arrêter mes apps ?",
    a: "Oui — wishlist, upsell, cross-sell, paliers panier, countdown, quick-add, stories, comparatifs avant/après… tout est natif dans le thème. Tu coupes les abonnements et tu gardes le cash (entre 400€ et 1000€/mois en moyenne).",
  },
  {
    q: "Combien de temps pour lancer ma boutique ?",
    a: "15 minutes pour avoir un site debout grâce aux modèles pré-construits (tu choisis une démo en 1 clic). Ensuite, quelques heures pour brander à tes couleurs et ajouter tes produits. Pas besoin de dev.",
  },
  {
    q: "Combien ça coûte ?",
    a: "19,99€/mois, tout inclus : accès au thème, mises à jour à vie, support prioritaire. Tu peux annuler à tout moment. Un seul coût qui remplace des centaines d'euros d'apps.",
  },
  {
    q: "Y a-t-il du support ?",
    a: "Support prioritaire par email, réponse sous 24h ouvrées. Onboarding assisté la première semaine si tu veux être guidé.",
  },
];
---

<LayoutPunchy
  title="Experaise — Le thème Shopify qui fait vendre · 19,99€/mois"
  description="Experaise : le thème Shopify qui remplace tes apps. +40 fonctionnalités de conversion intégrées (upsell, cross-sell, paliers panier, wishlist…), lancement en 15 min, ~500€/mois économisés. 19,99€/mois sans engagement."
>

  <!-- ================================================================
       HERO — Nom du thème + pitch + CTA + visuel principal
       ================================================================ -->
  <section class="pt-20 md:pt-28 pb-16">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-start">
        <!-- Colonne gauche : pitch -->
        <div
          class="md:col-span-7 bg-paper-2 border-2 border-ink rounded-sketch-b p-8 md:p-12 flex flex-col justify-between min-h-[480px] md:h-[580px] shadow-punch-lg"
        >
          <div>
            <p
              class="font-mono text-xs uppercase tracking-[0.15em] text-muted mb-6"
            >
              // thème shopify · fait main à rennes
            </p>

            <!-- Eyebrow / badge -->
            <div class="flex items-center gap-3 mb-8">
              <span
                class="inline-block font-mono text-[11px] uppercase tracking-wider bg-ink text-paper px-2 py-1"
              >
                NEW
              </span>
              <span class="font-note text-2xl text-ink">
                le thème qui fait vendre
              </span>
            </div>

            <!-- Titre XXL -->
            <h1
              class="font-display leading-[0.95] text-[44px] md:text-[68px] tracking-tight text-ink"
            >
              Plus de ventes.<br />
              Moins d'<span
                class="underline decoration-[5px] underline-offset-[6px] decoration-orange"
                >apps</span
              >.
            </h1>

            <p class="font-body text-lg md:text-xl mt-8 max-w-lg leading-snug">
              Experaise, c'est le thème Shopify pensé pour faire grimper ton
              CA. Upsell, cross-sell, paliers panier, wishlist, countdown…
              40+ fonctionnalités de conversion déjà natives — 400 à
              1000€/mois d'apps en moins, et des clients qui passent à
              l'achat.
            </p>
          </div>

          <!-- CTA row -->
          <div class="flex flex-wrap items-center gap-4 mt-10">
            <a
              href="#demo"
              class="inline-flex items-center gap-2 bg-orange text-white border-2 border-ink rounded-sketch-a px-6 py-3 font-mono text-sm font-semibold shadow-punch-sm"
              data-cursor="hover"
            >
              → Voir la démo
            </a>
            <a
              href="#get"
              class="inline-flex items-center gap-2 bg-paper text-ink border-2 border-ink rounded-sketch-a px-6 py-3 font-mono text-sm font-semibold"
              data-cursor="hover"
            >
              Démarrer l'abonnement
            </a>
            <span class="font-note text-xl text-ink">
              <strong class="font-bold">19,99€</strong>&nbsp;/mois
            </span>
          </div>
        </div>

        <!-- Colonne droite : visuel principal -->
        <div
          class="md:col-span-5 border-2 border-ink rounded-sketch-b overflow-hidden relative flex flex-col h-[420px] md:h-[580px] shadow-punch-lg"
        >
          <div class="flex-1 bg-paper-2 overflow-hidden">
            <img
              src="/images/theme-experaise-fullpage.png"
              alt="Experaise — aperçu du thème en contexte"
              loading="eager"
              decoding="async"
              class="block w-full h-full object-cover object-top"
            />
          </div>
          <div
            class="bg-ink text-paper font-mono text-[11px] uppercase tracking-[0.15em] px-4 py-3 flex justify-between border-t-2 border-ink shrink-0"
          >
            <span>// preview.01</span>
            <span>desktop · 1440</span>
          </div>
        </div>
      </div>

      <!-- Meta bar -->
      <div
        class="mt-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-3 font-mono text-xs uppercase tracking-[0.15em] text-muted"
      >
        <div class="flex items-center gap-2">
          <span class="inline-block w-2 h-2 rounded-full bg-orange animate-pulse"></span>
          v1.0 · stable
        </div>
        <div>Shopify OS 2.0 · 0 dépendance</div>
        <div>MAJ 04/2026</div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       MARQUEE — Mots-clés du thème
       ================================================================ -->
  <div
    class="marquee-punchy relative overflow-hidden border-y-2 border-ink bg-paper py-6"
  >
    <div class="marquee-punchy-track">
      {
        [...Array(3)].flatMap(() => [
          "Plus de CA",
          "Panier moyen ↑",
          "Vitesse max",
          "~500€/mois économisés",
          "Tout inclus",
        ]).map((s) => (
          <div class="flex items-center gap-8 flex-shrink-0">
            <span class="font-display text-3xl md:text-4xl text-ink whitespace-nowrap">
              {s}
            </span>
            <span class="inline-block w-3 h-3 rounded-full bg-orange flex-shrink-0" />
          </div>
        ))
      }
    </div>
  </div>

  <!-- ================================================================
       DEMO / SHOWCASE — Captures du thème en contexte
       ================================================================ -->
  <section id="demo" class="py-20 md:py-28">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10">
      <!-- Header section -->
      <div class="flex items-end justify-between mb-12 md:mb-16">
        <div>
          <p
            class="font-mono text-xs uppercase tracking-[0.15em] text-muted mb-3"
          >
            // 01 — En contexte
          </p>
          <h2
            class="font-display text-[48px] md:text-[88px] leading-[0.95] text-ink"
          >
            Le thème <span class="text-orange">en vrai</span>.
          </h2>
        </div>
        <a
          href="#"
          class="hidden md:inline-flex font-mono text-sm text-ink hover:text-orange transition-colors border-b-2 border-ink pb-1"
        >
          Tester la démo live →
        </a>
      </div>

      <!-- Grille de previews -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Grand preview (span 2 cols) — fenêtre navigateur scrollable -->
        <div
          class="md:col-span-2 bg-paper-2 border-2 border-ink rounded-sketch-b p-6 md:p-8"
        >
          <div class="flex items-center justify-between mb-4">
            <span
              class="font-mono text-[11px] uppercase tracking-wider bg-orange text-white px-2 py-1 border-2 border-ink"
            >
              Page d'accueil — scroll ↓
            </span>
            <span class="font-mono text-xs text-muted">[screen · 01]</span>
          </div>

          <!-- Browser window mockup -->
          <div
            class="browser-mockup border-2 border-ink rounded-sketch-a overflow-hidden bg-paper shadow-punch-md"
          >
            <!-- Chrome / barre supérieure -->
            <div
              class="flex items-center gap-3 bg-paper-2 border-b-2 border-ink px-4 py-3"
            >
              <!-- Traffic lights -->
              <div class="flex items-center gap-2">
                <span
                  class="inline-block w-3 h-3 rounded-full bg-[#ff5f57] border border-ink/30"
                ></span>
                <span
                  class="inline-block w-3 h-3 rounded-full bg-[#febc2e] border border-ink/30"
                ></span>
                <span
                  class="inline-block w-3 h-3 rounded-full bg-[#28c840] border border-ink/30"
                ></span>
              </div>
              <!-- URL bar -->
              <div
                class="flex-1 bg-paper border-2 border-ink rounded-sketch-c px-3 py-1 font-mono text-[11px] text-ink-soft truncate"
              >
                experaise.myshopify.com
              </div>
              <span class="hidden sm:inline font-mono text-[11px] text-muted"
                >⟳</span
              >
            </div>

            <!-- Viewport scrollable -->
            <div class="browser-viewport bg-paper">
              <img
                src="/images/theme-experaise-fullpage.png"
                alt="Thème Experaise — aperçu fullpage scrollable"
                loading="lazy"
                decoding="async"
                class="block w-full h-auto"
              />
            </div>
          </div>

          <!-- Hint scroll -->
          <p
            class="font-note text-lg text-muted mt-3 flex items-center gap-2"
          >
            <span class="font-mono text-xs uppercase tracking-[0.15em]"
              >scroll inside</span
            >
            <span>↓</span>
          </p>
        </div>

        <!-- Preview mobile — fiche produit dans un phone mockup scrollable -->
        <div
          class="bg-paper-2 border-2 border-ink rounded-sketch-b p-6 md:p-8 flex flex-col"
        >
          <div class="flex items-center justify-between mb-4">
            <span
              class="font-mono text-[11px] uppercase tracking-wider bg-ink text-paper px-2 py-1"
            >
              Mobile · PDP — scroll ↓
            </span>
            <span class="font-mono text-xs text-muted">[screen · 02]</span>
          </div>

          <!-- Phone mockup -->
          <div
            class="phone-mockup mx-auto flex-1 flex items-center justify-center py-4"
          >
            <div class="phone-frame">
              <!-- Notch -->
              <div class="phone-notch"></div>
              <!-- Viewport scrollable -->
              <div class="phone-viewport">
                <img
                  src="/images/theme-experaise-mobile-product-page.png"
                  alt="Thème Experaise — fiche produit mobile"
                  loading="lazy"
                  decoding="async"
                  class="block w-full h-auto"
                />
              </div>
            </div>
          </div>

          <p
            class="font-note text-lg text-muted mt-3 text-center flex items-center justify-center gap-2"
          >
            <span class="font-mono text-xs uppercase tracking-[0.15em]"
              >scroll</span
            >
            <span>↓</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       FEATURES — Pourquoi ce thème ?
       ================================================================ -->
  <section class="py-20 md:py-28 bg-paper-2 border-y-2 border-ink">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10">
      <div class="mb-12 md:mb-16 max-w-3xl">
        <p
          class="font-mono text-xs uppercase tracking-[0.15em] text-muted mb-3"
        >
          // 02 — Pourquoi Experaise
        </p>
        <h2
          class="font-display text-[48px] md:text-[88px] leading-[0.95] text-ink"
        >
          Un thème. <span class="text-orange">Plus de CA</span>.
        </h2>
        <p class="font-body text-lg md:text-xl mt-6 leading-snug">
          Experaise n'est pas juste un beau thème : c'est un système de
          croissance e-commerce. Tu customises ta boutique en quelques clics,
          et toutes les fonctionnalités qui font vendre sont déjà dedans.
        </p>
      </div>

      <!-- Grille features -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          features.map((f) => (
            <div class="bg-paper border-2 border-ink rounded-sketch-a p-6 flex flex-col gap-4 min-h-[220px]">
              <div class="flex items-start justify-between">
                <span class="font-display text-4xl text-orange leading-none">
                  {f.n}
                </span>
                <div class="placeholder-stripes border-2 border-ink w-14 h-14 rounded-sketch-c" />
              </div>
              <div>
                <h3 class="font-display text-2xl text-ink leading-tight mb-2">
                  {f.title}
                </h3>
                <p class="font-note text-xl text-muted leading-snug">
                  {f.hint}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ================================================================
       METRICS — Perfs chiffrées
       ================================================================ -->
  <section class="py-20 md:py-28">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10">
      <div class="mb-12 max-w-3xl">
        <p
          class="font-mono text-xs uppercase tracking-[0.15em] text-muted mb-3"
        >
          // 03 — Les chiffres qui comptent
        </p>
        <h2
          class="font-display text-[48px] md:text-[72px] leading-[0.95] text-ink"
        >
          Tout-en-<span class="text-orange">un</span>.
        </h2>
        <p class="font-body text-lg md:text-xl mt-6 leading-snug max-w-xl">
          Pourquoi payer 10 apps + un thème moyen quand tu peux tout avoir
          intégré, payé une fois ?
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {
          metrics.map((m) => (
            <div class="bg-paper border-2 border-ink rounded-sketch-b p-6 md:p-8 flex flex-col justify-between min-h-[180px] shadow-punch-sm">
              <div class="font-display text-5xl md:text-7xl text-orange leading-none">
                {m.value}
              </div>
              <div class="font-mono text-[11px] uppercase tracking-[0.15em] text-muted mt-4">
                {m.label}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ================================================================
       SECTIONS INCLUSES — Ce qu'il y a dans la boîte
       ================================================================ -->
  <section class="py-20 md:py-28 bg-paper-2 border-y-2 border-ink">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
        <!-- Titre colonne -->
        <div class="md:col-span-4">
          <p
            class="font-mono text-xs uppercase tracking-[0.15em] text-muted mb-3"
          >
            // 04 — Dans la boîte
          </p>
          <h2
            class="font-display text-[40px] md:text-[64px] leading-[0.95] text-ink"
          >
            38<br />
            <span class="text-orange">sections</span><br />
            prêtes.
          </h2>
          <p class="font-note text-2xl text-muted mt-6">
            + 75 blocks, drag & drop, activables en 1 clic.
          </p>
        </div>

        <!-- Liste sections -->
        <div class="md:col-span-8">
          <div
            class="bg-paper border-2 border-ink rounded-sketch-b p-6 md:p-8"
          >
            <ul class="grid grid-cols-2 md:grid-cols-3 gap-3">
              {
                sections.map((s, i) => (
                  <li class="flex items-center gap-3 border-b border-line-soft pb-3">
                    <span class="font-mono text-[11px] text-muted">
                      {String(i + 1).padStart(2, "0")}
                    </span>
                    <span class="font-body text-base md:text-lg text-ink">
                      {s}
                    </span>
                  </li>
                ))
              }
              <li
                class="flex items-center gap-3 border-b border-line-soft pb-3 font-mono text-xs uppercase tracking-wider text-muted"
              >
                + 26 autres…
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       TECH STACK — Sous le capot
       ================================================================ -->
  <section class="py-20 md:py-28">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10">
      <div class="mb-12 max-w-3xl">
        <p
          class="font-mono text-xs uppercase tracking-[0.15em] text-muted mb-3"
        >
          // 05 — Sous le capot
        </p>
        <h2
          class="font-display text-[48px] md:text-[72px] leading-[0.95] text-ink"
        >
          Propre. <span class="text-orange">Maintenable</span>.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Stack box -->
        <div
          class="bg-ink text-paper rounded-sketch-b border-2 border-ink p-6 md:p-8 font-mono text-sm leading-7"
        >
          <div class="text-orange uppercase tracking-[0.2em] text-[11px] mb-4">
            // stack.json
          </div>
          <pre class="whitespace-pre-wrap">{`{
  "platform": "Shopify OS 2.0",
  "language": "Liquid + Web Components",
  "js":       "ES6 modules · defer",
  "css":      "scoped par section",
  "a11y":     "WCAG 2.1 AA",
  "deps":     "0 (pas de jQuery)",
  "i18n":     "100% FR"
}`}</pre>
        </div>

        <!-- Checklist -->
        <div
          class="bg-paper-2 border-2 border-ink rounded-sketch-b p-6 md:p-8"
        >
          <div
            class="font-mono text-[11px] uppercase tracking-[0.2em] text-muted mb-4"
          >
            // checklist
          </div>
          <ul class="space-y-3 font-body text-base md:text-lg">
            <li class="flex items-start gap-3">
              <span class="text-orange font-display text-xl leading-none">✓</span>
              Scroll et animations fluides, même sur les pages longues
            </li>
            <li class="flex items-start gap-3">
              <span class="text-orange font-display text-xl leading-none">✓</span>
              Chaque section est indépendante — tu en ajoutes sans rien casser
            </li>
            <li class="flex items-start gap-3">
              <span class="text-orange font-display text-xl leading-none">✓</span>
              Mobile parfait : iPhone avec notch, Android, tout est propre
            </li>
            <li class="flex items-start gap-3">
              <span class="text-orange font-display text-xl leading-none">✓</span>
              Accessible à tout le monde : clavier, lecteurs d'écran, daltoniens
            </li>
            <li class="flex items-start gap-3">
              <span class="text-orange font-display text-xl leading-none">✓</span>
              Respecte les préférences de tes visiteurs (reduce-motion)
            </li>
            <li class="flex items-start gap-3">
              <span class="text-orange font-display text-xl leading-none">✓</span>
              Léger comme une plume. Ton Google PageSpeed va t'adorer.
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       FAQ
       ================================================================ -->
  <section class="py-20 md:py-28 bg-paper-2 border-y-2 border-ink">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
        <div class="md:col-span-4">
          <p
            class="font-mono text-xs uppercase tracking-[0.15em] text-muted mb-3"
          >
            // 06 — FAQ
          </p>
          <h2
            class="font-display text-[40px] md:text-[64px] leading-[0.95] text-ink"
          >
            Les<br />
            <span class="text-orange">questions</span><br />
            qu'on pose.
          </h2>
        </div>

        <div class="md:col-span-8 space-y-4">
          {
            faq.map((item, i) => (
              <details class="bg-paper border-2 border-ink rounded-sketch-a p-5 md:p-6 group">
                <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
                  <div class="flex items-start gap-4">
                    <span class="font-mono text-xs text-muted pt-1">
                      {String(i + 1).padStart(2, "0")}
                    </span>
                    <span class="font-body text-lg md:text-xl text-ink">
                      {item.q}
                    </span>
                  </div>
                  <span class="font-display text-3xl text-orange leading-none group-open:rotate-45 transition-transform">
                    +
                  </span>
                </summary>
                <p class="font-body text-base text-ink-soft leading-snug mt-4 pt-4 border-t border-line-soft">
                  {item.a}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       CTA FINAL — Get it
       ================================================================ -->
  <section id="get" class="py-20 md:py-32">
    <div class="max-w-[1440px] mx-auto px-6 md:px-10">
      <div
        class="bg-ink text-paper rounded-sketch-b border-2 border-ink p-8 md:p-20 relative overflow-hidden"
      >
        <p
          class="font-mono text-xs uppercase tracking-[0.15em] text-orange mb-8"
        >
          // passer à horizon
        </p>

        <h2
          class="font-display text-[56px] md:text-[120px] leading-[0.9] mb-8"
        >
          Passe à <span class="text-orange">Experaise</span>.
        </h2>

        <p
          class="font-body text-lg md:text-2xl text-paper/80 mb-12 max-w-2xl leading-snug"
        >
          19,99€/mois pour un thème qui remplace des centaines d'euros
          d'apps, te fait vendre plus et lance ta boutique en 15 minutes.
          Tu gagnes ton abonnement dès la première commande.
        </p>

        <!-- Price card -->
        <div
