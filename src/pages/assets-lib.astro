        { name: 'arrow_loop', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 80" fill="none" width="100" height="80"><path d="M10 60 Q 10 10 50 10 Q 90 10 90 40 Q 90 65 60 65" stroke="{{INK}}" stroke-width="2.5" stroke-linecap="round" fill="none"/><path d="M68 58 L58 65 L65 75" stroke="{{INK}}" stroke-width="2.5" stroke-linecap="round" fill="none"/></svg>` },
