---
// Page privée — Asset Library SVG (accessible uniquement via URL directe)
// Exclue du sitemap et noindex
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <title>Asset Library — SVG copy/paste</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Kalam:wght@300;400;700&family=Gloria+Hallelujah&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --ink: #1a1a1a;
        --paper: #fdfcf8;
        --paper-2: #f6f3ea;
        --orange: #FC5D10;
        --orange-soft: #ffe4d4;
        --hand: 'Kalam', cursive;
        --display: 'Gloria Hallelujah', cursive;
        --note: 'Caveat', cursive;
        --mono: 'JetBrains Mono', monospace;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: var(--paper); color: var(--ink); font-family: var(--hand); }

      .shell { max-width: 1400px; margin: 0 auto; padding: 48px 32px 120px; }

      header.top { display: flex; justify-content: space-between; align-items: flex-end; padding-bottom: 24px; border-bottom: 2px solid var(--ink); margin-bottom: 24px; }
      header.top h1 { font-family: var(--display); font-weight: 400; font-size: 56px; line-height: 0.95; margin: 0; }
      header.top h1 em { font-style: normal; color: var(--orange); }
      header.top .meta { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.2em; color: #555; text-align: right; line-height: 1.6; }
      header.top .meta b { color: var(--orange); }

      .intro { font-family: var(--hand); font-size: 17px; color: #333; max-width: 760px; line-height: 1.5; margin: 0 0 32px; }

      /* Sticky jump nav */
      .jumpnav {
        position: sticky; top: 0; z-index: 20;
        background: var(--paper);
        border-bottom: 2px solid var(--ink);
        padding: 14px 32px;
        margin: 0 -32px 40px;
        display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
      }
      .jumpnav .lbl { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.2em; color: #777; }
      .jumpnav a {
        font-family: var(--mono); font-size: 11px;
        text-transform: uppercase; letter-spacing: 0.1em;
        color: var(--ink); text-decoration: none;
        padding: 5px 10px; border: 2px solid var(--ink);
        border-radius: 4px 12px 4px 12px;
        transition: all 120ms;
      }
      .jumpnav a:hover { background: var(--orange); color: white; transform: translate(-1px,-1px); box-shadow: 3px 3px 0 var(--ink); }

      /* Section headers */
      .section-title { display: flex; align-items: baseline; gap: 18px; margin: 56px 0 20px; scroll-margin-top: 90px; }
      .section-title .n { font-family: var(--display); color: var(--orange); font-size: 36px; line-height: 1; }
      .section-title h2 { font-family: var(--hand); font-weight: 700; font-size: 20px; text-transform: uppercase; letter-spacing: 0.1em; margin: 0; }
      .section-title .dot { flex: 1; border-bottom: 2px dotted #c9c4b5; transform: translateY(-4px); }
      .section-title .count { font-family: var(--mono); font-size: 11px; color: #777; text-transform: uppercase; letter-spacing: 0.15em; }

      /* Grid */
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 18px;
      }

      .card {
        background: var(--paper);
        border: 2px solid var(--ink);
        border-radius: 6px 18px 4px 14px;
        display: flex; flex-direction: column;
        overflow: hidden;
        position: relative;
        transition: transform 150ms cubic-bezier(0.22,1,0.36,1), box-shadow 150ms;
        cursor: pointer;
      }
      .card:hover { transform: translate(-3px,-3px); box-shadow: 5px 5px 0 var(--ink); }

      .card .preview {
        aspect-ratio: 4/3;
        display: flex; align-items: center; justify-content: center;
        background: var(--paper-2);
        padding: 20px;
        border-bottom: 2px solid var(--ink);
        overflow: hidden;
      }
      .card .preview svg { max-width: 100%; max-height: 100%; display: block; }
      .card.dark-bg .preview { background: var(--ink); }

      .card .footer {
        display: flex; align-items: center; justify-content: space-between;
        padding: 10px 14px;
        font-family: var(--mono); font-size: 11px;
        text-transform: uppercase; letter-spacing: 0.06em;
        gap: 8px;
      }
      .card .label { color: #333; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .card .copybtn {
        font-family: var(--mono); font-size: 10px;
        letter-spacing: 0.1em; text-transform: uppercase;
        background: var(--ink); color: white;
        border: none; padding: 6px 10px;
        border-radius: 3px;
        cursor: pointer;
        transition: background 120ms;
        white-space: nowrap;
      }
      .card .copybtn:hover { background: var(--orange); }
      .card.copied .copybtn { background: var(--orange); }
      .card.copied .copybtn::before { content: '✓ '; }

      /* Toolbar */
      .toolbar {
        position: fixed; bottom: 24px; right: 24px; z-index: 40;
        background: var(--paper); border: 2px solid var(--ink);
        border-radius: 6px 18px 4px 14px;
        box-shadow: 5px 5px 0 var(--ink);
        padding: 14px 16px;
        display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
        font-family: var(--hand); font-size: 14px;
        max-width: 440px;
      }
      .toolbar .grp { display: flex; align-items: center; gap: 6px; }
      .toolbar input[type=color] {
        padding: 0; width: 34px; height: 30px;
        border: 2px solid var(--ink);
        border-radius: 4px 10px 4px 10px;
        background: var(--paper);
        cursor: pointer;
      }
      .toolbar .lbl { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: #666; }
      .toolbar button {
        font-family: var(--mono); font-size: 11px;
        text-transform: uppercase; letter-spacing: 0.1em;
        background: var(--orange); color: white; border: 2px solid var(--ink);
        padding: 7px 12px; border-radius: 4px 12px 4px 12px;
        cursor: pointer;
        box-shadow: 3px 3px 0 var(--ink);
        transition: transform 120ms;
      }
      .toolbar button:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 var(--ink); }

      /* Toast */
      .toast {
        position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%) translateY(20px);
        background: var(--ink); color: white;
        font-family: var(--hand); font-weight: 700; font-size: 15px;
        padding: 10px 18px;
        border-radius: 4px 14px 4px 14px;
        border: 2px solid var(--orange);
        opacity: 0; pointer-events: none;
        transition: opacity 200ms, transform 200ms;
        z-index: 100;
      }
      .toast.on { opacity: 1; transform: translateX(-50%) translateY(0); }

      .footer-note {
        margin-top: 80px; text-align: center;
        font-family: var(--note); font-size: 22px; color: #555;
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="top">
        <h1>Asset <em>library</em> · SVG</h1>
        <div class="meta">
          PRESS COPY · PASTE ANYWHERE<br />
          <b>→ tout en SVG pur, éditable Figma</b>
        </div>
      </header>

      <p class="intro">
        Bibliothèque complète de la DA — flèches, icônes, annotations, tampons, soulignements, bullets.
        Chaque bloc a son bouton <b>COPY SVG</b> : un clic, le SVG est dans ton presse-papier.
        Change les couleurs en live avec le panneau en bas à droite (ça met à jour les SVG exportés).
      </p>

      <nav class="jumpnav">
        <span class="lbl">Jump →</span>
        <a href="#arrows">Arrows</a>
        <a href="#icons">Icons</a>
        <a href="#annots">Annotations</a>
        <a href="#stamps">Stamps</a>
        <a href="#underlines">Underlines</a>
        <a href="#bullets">Bullets</a>
        <a href="#buttons">Buttons</a>
      </nav>

      <div class="section-title" id="arrows">
        <span class="n">❶</span><h2>Arrows</h2><span class="dot"></span><span class="count">8 assets</span>
      </div>
      <div class="grid" id="grid-arrows"></div>

      <div class="section-title" id="icons">
        <span class="n">❷</span><h2>Icons · e-com</h2><span class="dot"></span><span class="count">10 assets</span>
      </div>
      <div class="grid" id="grid-icons"></div>

      <div class="section-title" id="annots">
        <span class="n">❸</span><h2>Annotations · numbered &amp; notes</h2><span class="dot"></span><span class="count">10 assets</span>
      </div>
      <div class="grid" id="grid-annots"></div>

      <div class="section-title" id="stamps">
        <span class="n">❹</span><h2>Stamps · Badges</h2><span class="dot"></span><span class="count">6 assets</span>
      </div>
      <div class="grid" id="grid-stamps"></div>

      <div class="section-title" id="underlines">
        <span class="n">❺</span><h2>Underlines &amp; scribbles</h2><span class="dot"></span><span class="count">6 assets</span>
      </div>
      <div class="grid" id="grid-underlines"></div>

      <div class="section-title" id="bullets">
        <span class="n">❻</span><h2>Bullets · separators</h2><span class="dot"></span><span class="count">8 assets</span>
      </div>
      <div class="grid" id="grid-bullets"></div>

      <div class="section-title" id="buttons">
        <span class="n">❼</span><h2>Buttons · SVG</h2><span class="dot"></span><span class="count">6 assets</span>
      </div>
      <div class="grid" id="grid-buttons"></div>

      <p class="footer-note">→ Tout est en SVG pur · pas de dépendance · copie &amp; colle où tu veux</p>
    </div>

    <div class="toolbar">
      <span class="lbl">Colors</span>
      <div class="grp">
        <input type="color" id="c-orange" value="#FC5D10" title="Orange" />
        <input type="color" id="c-ink" value="#1a1a1a" title="Ink" />
      </div>
      <button id="reset-colors">reset</button>
      <span class="lbl">· click card → copy SVG</span>
    </div>

    <div class="toast" id="toast">→ SVG copié</div>

    <script is:inline>
      // Palette mutable — injectée dans chaque SVG au moment de la copie
      const COLORS = { orange: '#FC5D10', ink: '#1a1a1a' };

      const ARROWS = [
