        { name: 'circle_highlight', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 80" fill="none" width="200" height="80"><path d="M30 70 Q 5 40 20 20 Q 60 0 130 8 Q 195 14 185 50 Q 175 78 100 70 Q 50 65 30 60" stroke="{{ORANGE}}" stroke-width="3" stroke-linecap="round" fill="none"/></svg>` },
