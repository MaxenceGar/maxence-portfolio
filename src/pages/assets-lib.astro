      const ICONS = [
        { name: 'shopify_bag', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 60" fill="none" width="60" height="60"><path d="M15 22 L15 50 L45 50 L45 22 Z" stroke="{{INK}}" stroke-width="2.5" fill="none"/><path d="M22 22 Q 22 10 30 10 Q 38 10 38 22" stroke="{{INK}}" stroke-width="2.5" fill="none"/><circle cx="30" cy="34" r="3" fill="{{ORANGE}}"/></svg>` },
