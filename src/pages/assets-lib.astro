        { name: 'stamp_no_bs', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 60" fill="none" width="160" height="60"><g transform="rotate(2 80 30)"><rect x="10" y="12" width="140" height="40" fill="{{INK}}"/><rect x="6" y="8" width="140" height="40" fill="white" stroke="{{INK}}" stroke-width="2"/><text x="76" y="34" text-anchor="middle" font-family="Kalam, cursive" font-weight="700" font-size="18" fill="{{INK}}">No-bullshit</text></g></svg>` },
