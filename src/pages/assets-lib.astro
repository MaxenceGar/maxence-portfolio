        { name: 'highlight_block', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 40" fill="none" width="200" height="40"><rect x="6" y="8" width="188" height="24" fill="{{ORANGE}}" opacity="0.35"/></svg>` },
        { name: 'cross_out', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 30" fill="none" width="200" height="30"><path d="M5 18 L 195 12" stroke="{{ORANGE}}" stroke-width="4" stroke-linecap="round" fill="none"/></svg>` },
      ];

      const BULLETS = [
        { name: 'dot_solid', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" fill="none" width="30" height="30"><circle cx="15" cy="15" r="8" fill="{{ORANGE}}"/></svg>` },
        { name: 'dot_ringed', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" fill="none" width="30" height="30"><circle cx="15" cy="15" r="6" fill="{{ORANGE}}"/><circle cx="15" cy="15" r="11" stroke="{{INK}}" stroke-width="2" fill="none"/></svg>` },
        { name: 'square_solid', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" fill="none" width="30" height="30"><rect x="7" y="7" width="16" height="16" fill="{{INK}}"/></svg>` },
        { name: 'diamond', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" fill="none" width="30" height="30"><path d="M15 4 L 26 15 L 15 26 L 4 15 Z" fill="{{ORANGE}}"/></svg>` },
        { name: 'star_5pt', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" fill="none" width="30" height="30"><path d="M15 3 L18.5 11 L27 12 L20 18 L22 27 L15 22 L8 27 L10 18 L3 12 L11.5 11 Z" fill="{{ORANGE}}"/></svg>` },
        { name: 'plus_thick', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" fill="none" width="30" height="30"><path d="M15 4 L 15 26 M 4 15 L 26 15" stroke="{{ORANGE}}" stroke-width="4" stroke-linecap="round" fill="none"/></svg>` },
        { name: 'separator_dashes', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 20" fill="none" width="200" height="20"><path d="M5 10 L 195 10" stroke="{{INK}}" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="6 8" fill="none"/></svg>` },
        { name: 'separator_dots', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 20" fill="none" width="200" height="20"><circle cx="20" cy="10" r="3" fill="{{ORANGE}}"/><circle cx="60" cy="10" r="3" fill="{{INK}}"/><circle cx="100" cy="10" r="3" fill="{{ORANGE}}"/><circle cx="140" cy="10" r="3" fill="{{INK}}"/><circle cx="180" cy="10" r="3" fill="{{ORANGE}}"/></svg>` },
      ];

      const BUTTONS = [
        { name: 'btn_primary', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 60" fill="none" width="200" height="60"><path d="M10 10 Q 10 6 14 6 L 186 6 Q 194 6 194 18 L 194 44 Q 194 54 184 54 L 14 54 Q 6 54 6 46 L 6 18 Q 6 10 14 10 Z" fill="{{INK}}"/><path d="M10 8 Q 10 4 14 4 L 186 4 Q 194 4 194 16 L 194 42 Q 194 52 184 52 L 14 52 Q 6 52 6 44 L 6 16 Q 6 8 14 8 Z" fill="{{ORANGE}}" stroke="{{INK}}" stroke-width="2"/><text x="100" y="33" text-anchor="middle" font-family="Kalam, cursive" font-weight="700" font-size="16" fill="white">📅 Prendre un call →</text></svg>` },
        { name: 'btn_ghost', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 60" fill="none" width="200" height="60"><path d="M10 8 Q 10 4 14 4 L 186 4 Q 194 4 194 16 L 194 42 Q 194 52 184 52 L 14 52 Q 6 52 6 44 L 6 16 Q 6 8 14 8 Z" fill="transparent" stroke="{{INK}}" stroke-width="2"/><text x="100" y="33" text-anchor="middle" font-family="Kalam, cursive" font-weight="700" font-size="16" fill="{{INK}}">Voir les projets</text></svg>` },
        { name: 'btn_dark', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 60" fill="none" width="200" height="60"><path d="M10 8 Q 10 4 14 4 L 186 4 Q 194 4 194 16 L 194 42 Q 194 52 184 52 L 14 52 Q 6 52 6 44 L 6 16 Q 6 8 14 8 Z" fill="{{INK}}" stroke="{{INK}}" stroke-width="2"/><text x="100" y="34" text-anchor="middle" font-family="Kalam, cursive" font-weight="700" font-size="16" fill="white">→ contact.sh</text></svg>` },
        { name: 'btn_outline_orange', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 60" fill="none" width="200" height="60"><path d="M10 8 Q 10 4 14 4 L 186 4 Q 194 4 194 16 L 194 42 Q 194 52 184 52 L 14 52 Q 6 52 6 44 L 6 16 Q 6 8 14 8 Z" fill="transparent" stroke="{{ORANGE}}" stroke-width="2"/><text x="100" y="33" text-anchor="middle" font-family="Kalam, cursive" font-weight="700" font-size="16" fill="{{ORANGE}}">Lire la suite</text></svg>` },
        { name: 'btn_pill', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 60" fill="none" width="200" height="60"><rect x="10" y="12" width="184" height="40" rx="20" fill="{{INK}}"/><rect x="6" y="8" width="184" height="40" rx="20" fill="{{ORANGE}}" stroke="{{INK}}" stroke-width="2"/><text x="98" y="33" text-anchor="middle" font-family="Kalam, cursive" font-weight="700" font-size="15" fill="white">→ LinkedIn</text></svg>` },
        { name: 'btn_chip_mono', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 40" fill="none" width="140" height="40"><rect x="4" y="4" width="128" height="28" rx="4" fill="transparent" stroke="{{INK}}" stroke-width="2"/><text x="68" y="23" text-anchor="middle" font-family="JetBrains Mono, monospace" font-weight="600" font-size="11" fill="{{INK}}" letter-spacing="2">VITESSE</text></svg>` },
      ];

      function applyPalette(svg) {
        return svg.replaceAll('{{ORANGE}}', COLORS.orange).replaceAll('{{INK}}', COLORS.ink);
      }

      function renderGrid(id, items, darkPreview = false) {
        const grid = document.getElementById(id);
        items.forEach(item => {
          const card = document.createElement('div');
          card.className = 'card' + (darkPreview ? ' dark-bg' : '');

          const preview = document.createElement('div');
          preview.className = 'preview';
          preview.innerHTML = applyPalette(item.svg);
          card.appendChild(preview);

          const footer = document.createElement('div');
          footer.className = 'footer';
          const label = document.createElement('span');
          label.className = 'label';
          label.textContent = item.name;
          const btn = document.createElement('button');
          btn.className = 'copybtn';
          btn.textContent = 'Copy SVG';
          footer.appendChild(label);
          footer.appendChild(btn);
          card.appendChild(footer);

          const copy = async () => {
            const out = applyPalette(item.svg);
            try {
              await navigator.clipboard.writeText(out);
              card.classList.add('copied');
              showToast('✓ ' + item.name + ' copié');
              setTimeout(() => card.classList.remove('copied'), 1500);
            } catch (e) {
              showToast('✗ copy failed');
            }
          };
          card.addEventListener('click', copy);
          grid.appendChild(card);
        });
      }

      function rerenderAll() {
        document.querySelectorAll('.grid').forEach(g => g.innerHTML = '');
        renderGrid('grid-arrows', ARROWS);
        renderGrid('grid-icons', ICONS);
        renderGrid('grid-annots', ANNOTS);
        renderGrid('grid-stamps', STAMPS);
        renderGrid('grid-underlines', UNDERLINES);
        renderGrid('grid-bullets', BULLETS);
        renderGrid('grid-buttons', BUTTONS);
      }
      rerenderAll();

      const toast = document.getElementById('toast');
      let toastTO;
      function showToast(msg) {
        toast.textContent = msg;
        toast.classList.add('on');
        clearTimeout(toastTO);
        toastTO = setTimeout(() => toast.classList.remove('on'), 1600);
      }

      const cOrange = document.getElementById('c-orange');
      const cInk = document.getElementById('c-ink');
      function syncColors() {
        COLORS.orange = cOrange.value;
        COLORS.ink = cInk.value;
        document.documentElement.style.setProperty('--orange', cOrange.value);
        document.documentElement.style.setProperty('--ink', cInk.value);
        rerenderAll();
      }
      cOrange.addEventListener('input', syncColors);
      cInk.addEventListener('input', syncColors);
      document.getElementById('reset-colors').addEventListener('click', () => {
        cOrange.value = '#FC5D10';
        cInk.value = '#1a1a1a';
        syncColors();
      });
    </script>
  </body>
</html>
