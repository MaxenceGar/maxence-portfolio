---
const services = [
  'Vitesse & Core Web Vitals',
  'Refonte de thème',
  'Dev custom',
  'Conseil CRO',
  'Optimisation CRO',
  'Liquid / Shopify 2.0',
];

const clients = [
  { name: 'Castafiore', logo: '/images/logo-castafiore.svg' },
  { name: 'Ohmycase', logo: '/images/logo-ohmycase.svg' },
  { name: 'Monsieur Madame', logo: '/images/logo-monsieur-madame.webp' },
  { name: 'Energie-fruit', logo: '/images/logo-energie-fruit.svg' },
];
---

<section class="pt-28 md:pt-32 pb-0">
  <div class="max-w-[1440px] mx-auto px-6 md:px-10">
    <!-- Split 50/50 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border-2 border-ink rounded-sketch-b overflow-hidden shadow-punch-lg">
      <!-- Bloc gauche : orange -->
      <div class="bg-orange text-white p-8 md:p-12 relative min-h-[420px] md:min-h-[560px] flex flex-col justify-between">
        <!-- Meta mono -->
        <div class="font-mono text-xs uppercase tracking-[0.15em] opacity-90">
          // shopify freelance · dispo maintenant
        </div>

        <!-- Headline XXL manuscrit -->
        <div class="py-8">
          <h1
            class="font-display leading-[0.95] text-[56px] md:text-[88px] tracking-tight"
          >
            Shopify <span class="underline decoration-[6px] underline-offset-[8px] decoration-white">expert</span>.<br />
            Pas magicien.
          </h1>
          <p class="font-body text-lg md:text-xl mt-6 max-w-md leading-snug">
            Je prends ta boutique, je la rends plus rapide et plus claire. Sans jargon à rallonge.
          </p>
        </div>

        <!-- Badge rond bottom-right -->
        <div class="flex justify-end">
          <a
            href="#work"
            class="inline-flex items-center justify-center w-32 h-32 rounded-full border-2 border-white text-white font-mono text-xs uppercase tracking-wider text-center hover:bg-white hover:text-orange transition-colors"
            data-cursor="hover"
          >
            Voir les projets →
          </a>
        </div>
      </div>

      <!-- Bloc droite : paper -->
      <div class="bg-paper p-8 md:p-12 flex flex-col justify-between gap-8">
        <!-- Grille 2x2 de logos clients -->
        <div class="grid grid-cols-2 gap-4">
          {
            clients.map((client) => (
              <div
                class="bg-paper-2 border-2 border-ink rounded-sketch-a aspect-[4/3] flex items-center justify-center p-6"
              >
                <img
                  src={client.logo}
                  alt={`Logo ${client.name}`}
                  width="200"
                  height="150"
                  loading="lazy"
                  decoding="async"
                  class="max-w-full max-h-full object-contain"
                />
              </div>
            ))
          }
        </div>

        <!-- Tagline + CTA -->
        <div>
          <p class="font-note text-2xl md:text-3xl text-ink leading-snug mb-6">
            Pour les marques qui veulent un Shopify qui roule. Et les agences qui sous-traitent.
          </p>
          <a
            href="#contact"
            class="cta-pill inline-flex items-center gap-2 bg-orange text-white border-2 border-ink rounded-sketch-a px-6 py-3 font-mono text-sm font-semibold shadow-punch-sm"
            data-cursor="hover"
          >
            📅 Prendre un call →
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Marquee services -->
  <div class="marquee-punchy relative overflow-hidden border-y-2 border-ink bg-paper mt-16 py-6">
    <div class="marquee-punchy-track">
      {
        [...services, ...services, ...services].map((s) => (
          <div class="flex items-center gap-8 flex-shrink-0">
            <span class="font-display text-3xl md:text-4xl text-ink whitespace-nowrap">
              {s}
            </span>
            <span class="inline-block w-3 h-3 rounded-full bg-[#FC5D10] flex-shrink-0"></span>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Bande info -->
  <div class="max-w-[1440px] mx-auto px-6 md:px-10 py-6">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 font-mono text-xs uppercase tracking-[0.15em] text-muted">
      <div class="flex items-center gap-2">
        <span class="inline-block w-2 h-2 rounded-full bg-orange animate-pulse"></span>
        Dispo pour nouveaux projets
      </div>
      <div>Basé à Rennes · Remote friendly</div>
      <div>5 ans sur Shopify</div>
    </div>
  </div>
</section>
