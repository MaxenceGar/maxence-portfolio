---
import "../styles/global.css";
---

<footer
  class="bg-black/90 text-[#F5F5F5] py-10 md:py-14 border-t border-white/10 font-title"
>
  <div
    class="w-11/12 md:w-3/4 mx-auto flex flex-col md:flex-row justify-between items-center gap-6"
  >
    <p class="text-xl tracking-widest">
      © {new Date().getFullYear()} Maxence Garandel
    </p>

    <div class="flex gap-6 text-lg md:text-xl">
      <a
        href="https://www.linkedin.com/in/maxence-garandel"
        target="_blank"
        class="hover:text-green-400 transition">LinkedIn</a
      >
      <a
        href="mailto:maxgarandel.pro@gmail.com"
        class="hover:text-green-400 transition">Contact</a
      >
    </div>
  </div>
</footer>
