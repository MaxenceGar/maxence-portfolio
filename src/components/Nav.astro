---
// Nav sticky : transparent sur hero, fond paper avec bordure basse après scroll
---

<nav
  data-nav
  class="nav-punchy fixed top-0 left-0 right-0 z-20 transition-colors duration-300"
>
  <div class="max-w-[1440px] mx-auto px-6 md:px-10 py-5 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2 font-mono text-sm md:text-base font-semibold text-ink"
    >
      <span class="inline-block w-3 h-3 rounded-full bg-[#FC5D10]"></span>
      maxence.garandel
    </a>

    <!-- Liens -->
    <div class="hidden md:flex items-center gap-8 font-mono text-sm">
      <a href="/#work" class="text-ink hover:text-orange transition-colors">projets</a>
      <a href="/#services" class="text-ink hover:text-orange transition-colors">services</a>
      <a
        href="/mon-theme"
        class="text-ink hover:text-orange transition-colors inline-flex items-center gap-1.5"
      >
        experaise
        <span
          class="inline-block text-[9px] uppercase tracking-wider bg-ink text-paper px-1.5 py-0.5"
        >new</span>
      </a>
      <a href="/#contact" class="text-orange font-semibold">
        prendre un call ↗
      </a>
    </div>

    <!-- Mobile CTA -->
    <div class="md:hidden flex items-center gap-4 font-mono text-xs">
      <a href="/mon-theme" class="text-ink inline-flex items-center gap-1">
        experaise
        <span class="inline-block text-[8px] uppercase tracking-wider bg-ink text-paper px-1 py-0.5">new</span>
      </a>
      <a href="/#contact" class="text-orange font-semibold">
        calendly ↗
      </a>
    </div>
  </div>
</nav>

<style>
  .nav-punchy {
    background: transparent;
    border-bottom: 2px solid transparent;
  }
  .nav-punchy.is-scrolled {
    background: #fdfcf8;
    border-bottom: 2px solid #1a1a1a;
  }
</style>
