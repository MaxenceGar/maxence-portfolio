---
import "../styles/global.css";
import { Icon } from "astro-icon/components";
import { motion } from "framer-motion";
---

<section class="relative py-24 bg-white text-black container mx-auto px-2 font-title">
  <div class="mb-16">
    <h2
      class="text-3xl md:text-5xl font-bold text-black mb-4 text-center md:text-left"
    >
      Formation & Compétences
    </h2>
    <p class="text-gray-700 max-w-2xl text-center md:text-left">
      Un parcours orienté web-marketing et communication digitale
    </p>
  </div>

  <div class="relative grid md:grid-cols-2 grid-cols-1 gap-8 mb-16">
    <motion.div
      client:visible
      initial={{ x: -50, opacity: 0 }}
      animate={{ x: 0, opacity: 1 }}
      transition={{ duration: 0.6 }}
      className="bg-white rounded-2xl p-8 border border-[#FC5A0A]/30 hover:border-[#FC5A0A] hover:shadow-xl hover:shadow-[#FC5A0A]/20 transition-all"
    >
      <h3
        class="text-2xl md:text-3xl font-bold mb-8 text-[#FC5A0A] flex items-center gap-3"
      >
        🎓 Formation
      </h3>
      <div class="space-y-6">
        <div class="border-l-2 border-[#FC5A0A]/50 pl-4">
          <span class="text-[#FC5A0A] font-semibold text-lg">2022 - 2023</span>
          <p class="text-xl font-semibold mt-1">
            Bachelor Marketing & Social Media
          </p>
          <p class="text-gray-600 mt-1">My Digital School - Caen (14)</p>
        </div>
        <div class="border-l-2 border-[#FC5A0A]/50 pl-4">
          <span class="text-[#FC5A0A] font-semibold text-lg">2020 - 2022</span>
          <p class="text-xl font-semibold mt-1">BTS Communication</p>
          <p class="text-gray-600 mt-1">Rennes (35) & Caen (14)</p>
        </div>
        <div class="border-l-2 border-[#FC5A0A]/50 pl-4">
          <span class="text-[#FC5A0A] font-semibold text-lg">2015 - 2018</span>
          <p class="text-xl font-semibold mt-1">BAC STMG</p>
          <p class="text-gray-600 mt-1">Lannion (22)</p>
        </div>
      </div>
    </motion.div>

    <motion.div
      client:visible
      initial={{ x: 50, opacity: 0 }}
      animate={{ x: 0, opacity: 1 }}
      transition={{ duration: 0.6 }}
      className="bg-white rounded-2xl p-8 border border-[#FC5A0A]/30 hover:border-[#FC5A0A] hover:shadow-xl hover:shadow-[#FC5A0A]/20 transition-all"
    >
      <h3
        class="text-2xl md:text-3xl font-bold mb-8 text-[#FC5A0A] flex items-center gap-3"
      >
        💡 Compétences Clés
      </h3>
      <div class="space-y-6">
        <div>
          <p class="text-lg font-semibold mb-3 text-[#FC5A0A]">
            Marketing Digital
          </p>
          <div class="flex flex-wrap gap-2">
            <span
              class="px-3 py-1 bg-[#FC5A0A]/10 border border-[#FC5A0A]/30 rounded-full text-sm"
              >SEO</span
            >
            <span
              class="px-3 py-1 bg-[#FC5A0A]/10 border border-[#FC5A0A]/30 rounded-full text-sm"
              >Google Ads</span
            >
            <span
              class="px-3 py-1 bg-[#FC5A0A]/10 border border-[#FC5A0A]/30 rounded-full text-sm"
              >Meta Ads</span
            >
            <span
              class="px-3 py-1 bg-[#FC5A0A]/10 border border-[#FC5A0A]/30 rounded-full text-sm"
              >Analytics</span
            >
          </div>
        </div>
        <div>
          <p class="text-lg font-semibold mb-3 text-[#FC5A0A]">
            Communication & Contenu
          </p>
          <div class="flex flex-wrap gap-2">
            <span
              class="px-3 py-1 bg-[#FC5A0A]/10 border border-[#FC5A0A]/30 rounded-full text-sm"
              >Réseaux sociaux</span
            >
            <span
              class="px-3 py-1 bg-[#FC5A0A]/10 border border-[#FC5A0A]/30 rounded-full text-sm"
              >Rédaction web</span
            >
            <span
              class="px-3 py-1 bg-[#FC5A0A]/10 border border-[#FC5A0A]/30 rounded-full text-sm"
              >Email Marketing</span
            >
          </div>
        </div>
        <div>
          <p class="text-lg font-semibold mb-3 text-[#FC5A0A]">
            Outils & Plateformes
          </p>
          <div class="flex gap-4 flex-wrap mt-3">
            <Icon
              name="shopify"
              class="w-8 h-8 text-[#FC5A0A]"
              title="Shopify"
            />
            <Icon name="figma" class="w-8 h-8 text-[#FC5A0A]" title="Figma" />
            <Icon name="adobe" class="w-8 h-8 text-[#FC5A0A]" title="Adobe" />
            <Icon
              name="wordpress"
              class="w-8 h-8 text-[#FC5A0A]"
              title="WordPress"
            />
            <Icon
              name="openai"
              class="w-8 h-8 text-[#FC5A0A]"
              title="AI Tools"
            />
          </div>
        </div>
      </div>
    </motion.div>
  </div>
  <div class="mt-8">
    <h2
      class="text-3xl md:text-5xl font-bold text-black mb-8 text-center md:text-left"
    >
      💼 Expériences Professionnelles
    </h2>

    <div class="space-y-6">
      <motion.div
        client:visible
        initial={{ y: 30, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
        transition={{ duration: 0.5, delay: 0.1 }}
        className="bg-white rounded-2xl p-6 md:p-8 border border-[#FC5A0A]/30 hover:border-[#FC5A0A] hover:shadow-xl hover:shadow-[#FC5A0A]/20 transition-all"
      >
        <div
          class="flex flex-col md:flex-row md:justify-between md:items-start gap-4 mb-4"
        >
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span
                class="bg-[#FC5A0A]/10 text-[#FC5A0A] px-3 py-1 rounded-full text-sm font-semibold border border-[#FC5A0A]/30"
              >
                Septembre 2023 - Aujourd'hui
              </span>
              <span
                class="bg-[#FC5A0A] text-white px-3 py-1 rounded-full text-sm font-bold"
              >
                Freelance
              </span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-black">
              Expert E-commerce & Web-Marketing Digital
            </h3>
            <p class="text-gray-600 mt-1">Rennes (35)</p>
          </div>
        </div>
        <div class="mt-4 space-y-3">
          <p class="text-gray-700 leading-relaxed">
            Accompagnement de TPE et PME dans le développement de leur présence
            et performances digitales.
          </p>
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Conseil stratégique et accompagnement clients en communication
                digitale</span
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Création, maintenance et évolution de sites web (vitrines &
                e-commerce)</span
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Gestion technique de boutiques Shopify (produits, apps,
                personnalisation)</span
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Optimisation de l'expérience utilisateur et des taux de
                conversion</span
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Analyse des performances web et recommandations d'optimisation</span
              >
            </li>
          </ul>
        </div>
      </motion.div>

      <motion.div
        client:visible
        initial={{ y: 30, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
        transition={{ duration: 0.5, delay: 0.1 }}
        className="bg-white rounded-2xl p-6 md:p-8 border border-[#FC5A0A]/30 hover:border-[#FC5A0A] hover:shadow-xl hover:shadow-[#FC5A0A]/20 transition-all"
      >
        <div
          class="flex flex-col md:flex-row md:justify-between md:items-start gap-4 mb-4"
        >
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span
                class="bg-[#FC5A0A]/10 text-[#FC5A0A] px-3 py-1 rounded-full text-sm font-semibold border border-[#FC5A0A]/30"
              >
                Avril 2025 - Août 2025
              </span>
              <span
                class="bg-white text-[#FC5A0A] px-3 py-1 rounded-full text-sm font-bold border-2 border-[#FC5A0A]"
              >
                SupplyWeb
              </span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-black">
              Spécialiste préparation des commandes
            </h3>
            <p class="text-gray-600 mt-1">Caen (14)</p>
          </div>
        </div>
        <div class="mt-4 space-y-3">
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span>Préparation et expédition des commandes</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span>Respect des processus pour les commandes complexes</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span>Plus de 100 commandes préparées et expédiées par jour</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span>Formation des nouveaux arrivants</span>
            </li>
          </ul>
        </div>
      </motion.div>

      <motion.div
        client:visible
        initial={{ y: 30, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
        transition={{ duration: 0.5, delay: 0.2 }}
        className="bg-white rounded-2xl p-6 md:p-8 border border-[#FC5A0A]/30 hover:border-[#FC5A0A] hover:shadow-xl hover:shadow-[#FC5A0A]/20 transition-all"
      >
        <div
          class="flex flex-col md:flex-row md:justify-between md:items-start gap-4 mb-4"
        >
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span
                class="bg-[#FC5A0A]/10 text-[#FC5A0A] px-3 py-1 rounded-full text-sm font-semibold border border-[#FC5A0A]/30"
              >
                Septembre 2022 - Mars 2025
              </span>
              <span
                class="bg-white text-[#FC5A0A] px-3 py-1 rounded-full text-sm font-bold border-2 border-[#FC5A0A]"
              >
                OhMyCase
              </span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-black">
              Chargé de communication & Web‑marketing
            </h3>
            <p class="text-gray-600 mt-1">Alternance & CDI</p>
          </div>
        </div>
        <div class="mt-4 space-y-3">
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Gestion et configuration avancée de la boutique Shopify (10K+
                produits)</span
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Pilotage technique des temps forts e-commerce : +40% de trafic,
                +25% de CA (Black Friday, Noël)</span
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Déploiement de campagnes d'emailing et marketing automation via
                Klaviyo (+15% taux d'ouverture)</span
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Coordination technique de 20+ campagnes d'influence (suivi
                performances, ROI)</span
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Optimisation continue de l'expérience utilisateur et du taux de
                conversion (A/B testing, analytics)</span
              >
            </li>
          </ul>
        </div>
      </motion.div>

      <motion.div
        client:visible
        initial={{ y: 30, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
        transition={{ duration: 0.5, delay: 0.3 }}
        className="bg-white rounded-2xl p-6 md:p-8 border border-[#FC5A0A]/30 hover:border-[#FC5A0A] hover:shadow-xl hover:shadow-[#FC5A0A]/20 transition-all"
      >
        <div
          class="flex flex-col md:flex-row md:justify-between md:items-start gap-4 mb-4"
        >
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span
                class="bg-[#FC5A0A]/10 text-[#FC5A0A] px-3 py-1 rounded-full text-sm font-semibold border border-[#FC5A0A]/30"
              >
                Septembre 2021 - Août 2022
              </span>
              <span
                class="bg-white text-[#FC5A0A] px-3 py-1 rounded-full text-sm font-bold border-2 border-[#FC5A0A]"
              >
                MyFooty
              </span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-black">
              Assistant de communication
            </h3>
            <p class="text-gray-600 mt-1">Stage</p>
          </div>
        </div>
        <div class="mt-4 space-y-3">
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Gestion et mise à jour quotidienne du site web et du catalogue
                produits (500+ références)</span
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Création de contenus visuels et rédactionnels pour les réseaux
                sociaux et campagnes email</span
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Gestion des partenariats avec 15+ clubs amateurs et
                professionnels</span
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#FC5A0A] mt-1">•</span>
              <span
                >Support opérationnel aux actions de communication et événements
                sportifs</span
              >
            </li>
          </ul>
        </div>
      </motion.div>
    </div>
  </div>
</section>
