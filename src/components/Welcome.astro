---
import "../styles/global.css";
import AnimatedSection from "../components/AnimatedSection.jsx";
import React from "react";
import { motion } from "framer-motion";
import Marquee from "../components/MarqueeBrand.astro";
---

<section
  class="relative flex flex-col items-center text-center min-h-screen bg-white text-[#FC5A0A] font-title"
>
  <!-- Contenu centré verticalement -->
  <div class="flex-1 flex items-center justify-center w-full">
    <div class="md:w-3/4 w-11/12 mx-auto flex flex-col items-center">
      <!-- Badge -->
      <div
        class="items-center bg-[#FC5A0A]/10 px-5 py-2.5 rounded-lg border border-[#FC5A0A]/30 inline-block mb-6"
      >
        <span class="font-medium">Freelance spécialisé Shopify</span>
      </div>
      <!-- Titre -->
      <motion.h1
        className="text-4xl md:text-7xl font-title font-extrabold leading-tight mb-6"
        initial={{ y: -100, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
        transition={{
          type: "spring",
          stiffness: 50,
          damping: 20,
          delay: 0.3,
        }}
        client:visible
      >
        <span class="text-black"
          >Des boutiques Shopify <br />
          <span class="text-orange">conçues pour vendre</span></span
        >
      </motion.h1>
      <!-- Sous-titre -->
      <p class="text-lg md:text-xl text-gray-500 max-w-2xl mb-10 leading-relaxed">
        J'accompagne les marques ambitieuses dans la création et l'optimisation de leur boutique e-commerce. Plus de conversions, moins de friction.
      </p>
      <!-- Boutons -->
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="btn-primaire-max">
          <a href="/appel-decouverte">Réserver un appel</a>
        </div>
        <a
          href="/projets"
          class="px-6 py-3 rounded-xl border-2 border-gray-200 text-black font-bold hover:border-orange hover:text-orange transition-colors duration-300"
        >
          Voir mes projets
        </a>
      </div>
    </div>
  </div>
  <!-- Marquee en bas -->
  <div class="w-full">
    <Marquee />
  </div>
</section>
