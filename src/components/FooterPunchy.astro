---
const year = new Date().getFullYear();
---

<footer class="border-t-2 border-ink bg-paper">
  <div class="max-w-[1440px] mx-auto px-6 md:px-10 py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-4 items-center">
      <!-- Copyright -->
      <div class="font-body text-sm text-ink-soft">
        © {year} — Maxence Garandel
      </div>

      <!-- Localisation -->
      <div class="font-note text-lg text-ink text-center">
        Fait à Rennes, avec beaucoup de café.
      </div>

      <!-- Back to top -->
      <div class="flex md:justify-end">
        <a
          href="#top"
          class="font-mono text-sm text-ink hover:text-[#FC5D10] transition-colors inline-flex items-center gap-2"
          data-cursor="hover"
        >
          ↑ Retour en haut
        </a>
      </div>
    </div>
  </div>
</footer>
