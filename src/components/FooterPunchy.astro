---
const year = new Date().getFullYear();

const nav = [
  { label: "Projets", href: "/#work" },
  { label: "Services", href: "/#services" },
  { label: "Sections gratuites", href: "/sections-gratuites" },
  { label: "Contact", href: "/#contact" },
];

const contact = [
  {
    label: "Réserver un call",
    href: "https://calendly.com/maxgarandel-pro/30min",
    external: true,
  },
  {
    label: "maxgarandel.pro@gmail.com",
    href: "mailto:maxgarandel.pro@gmail.com",
  },
];
---

<footer class="border-t border-ink/10 bg-paper font-title">
  <div class="max-w-[1200px] mx-auto px-6 md:px-10 py-14 md:py-20">
    <!-- Top row : 3 colonnes -->
    <div
      class="grid grid-cols-2 md:grid-cols-3 gap-10 md:gap-12 pb-10 md:pb-12 border-b border-ink/10"
    >
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a
          href="/"
          class="inline-flex items-center gap-2 font-mono text-sm font-semibold text-ink hover:text-orange transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper rounded-sm"
        >
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-orange"></span>
          maxence.garandel
        </a>
        <p
          class="mt-4 font-light text-sm text-ink-soft leading-relaxed max-w-xs"
        >
          Freelance Shopify à Rennes. Je code des boutiques qui vendent, sans
          empiler les apps.
        </p>
      </div>

      <!-- Navigation -->
      <nav aria-labelledby="footer-nav-label">
        <p
          id="footer-nav-label"
          class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted mb-4"
        >
          Navigation
        </p>
        <ul class="space-y-2.5">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-ink-soft hover:text-orange transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper rounded-sm"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Contact -->
      <div aria-labelledby="footer-contact-label">
        <p
          id="footer-contact-label"
          class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted mb-4"
        >
          Contact
        </p>
        <ul class="space-y-2.5">
          {
            contact.map((item) => (
              <li>
                <a
                  href={item.href}
                  target={item.external ? "_blank" : undefined}
                  rel={item.external ? "noopener noreferrer" : undefined}
                  class="text-sm text-ink-soft hover:text-orange transition-colors break-words focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper rounded-sm"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom row : copyright + meta -->
    <div
      class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 pt-8 md:pt-10 font-mono text-[10px] uppercase tracking-[0.12em] text-muted"
    >
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5">
        <span>© {year} Maxence Garandel</span>
        <span
          class="hidden md:inline-block w-1 h-1 rounded-full bg-ink/20"
          aria-hidden="true"></span>
        <span>SIRET dispo</span>
        <span
          class="hidden md:inline-block w-1 h-1 rounded-full bg-ink/20"
          aria-hidden="true"></span>
        <span>Fait à Rennes</span>
      </div>
      <button
        type="button"
        data-scroll-top
        class="inline-flex items-center gap-1.5 hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange focus-visible:ring-offset-2 focus-visible:ring-offset-paper rounded-sm cursor-pointer"
        aria-label="Remonter en haut de page"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-3 h-3"
          aria-hidden="true"
        >
          <line x1="12" y1="19" x2="12" y2="5"></line>
          <polyline points="5 12 12 5 19 12"></polyline>
        </svg>
        Haut de page
      </button>
    </div>
  </div>
</footer>

<script is:inline>
  document.querySelectorAll("[data-scroll-top]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const reduce = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;
      window.scrollTo({ top: 0, behavior: reduce ? "auto" : "smooth" });
    });
  });
</script>
